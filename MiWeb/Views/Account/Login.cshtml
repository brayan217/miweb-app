@{
    ViewData["Title"] = "Iniciar Sesión - NEO STORE";
}

<style>
    .login-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
        background: #090909;
        position: relative;
        overflow: hidden;
    }

        .login-container::before {
            content: '';
            position: absolute;
            top: -30%;
            right: -10%;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(0,207,255,0.02) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

    .login-card {
        background: rgba(18, 18, 30, 0.4);
        border: 1px solid rgba(255,255,255,0.02);
        border-radius: 24px;
        padding: 50px 40px;
        max-width: 420px;
        width: 100%;
        backdrop-filter: blur(20px);
        position: relative;
        z-index: 1;
    }

        .login-card .logo {
            text-align: center;
            margin-bottom: 35px;
        }

            .login-card .logo h1 {
                font-family: 'Orbitron', sans-serif;
                font-weight: 900;
                font-size: 2rem;
                color: #fff;
                letter-spacing: -1px;
            }

                .login-card .logo h1 span {
                    background: linear-gradient(135deg, #00CFFF, #7A00FF);
                    -webkit-background-clip: text;
                    -webkit-text-fill-color: transparent;
                }

            .login-card .logo p {
                color: #FFFFFF;
                font-size: 0.85rem;
                letter-spacing: 1px;
            }

        .login-card .form-group {
            margin-bottom: 20px;
        }

        .login-card label {
            color: #FFFFFF;
            font-weight: 600;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 6px;
            display: block;
        }

        .login-card .form-control {
            background: rgba(255,255,255,0.02);
            border: 1px solid rgba(255,255,255,0.03);
            border-radius: 12px;
            color: #fff;
            padding: 14px 18px;
            width: 100%;
            transition: all 0.3s ease;
            font-size: 1rem;
        }

            .login-card .form-control:focus {
                outline: none;
                border-color: #00CFFF;
                box-shadow: 0 0 0 4px rgba(0,207,255,0.02);
                background: rgba(255,255,255,0.03);
            }

            .login-card .form-control::placeholder {
                color: #FFFFFF;
            }

        .login-card .form-check {
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 15px 0;
        }

            .login-card .form-check input[type="checkbox"] {
                accent-color: #00CFFF;
                width: 18px;
                height: 18px;
                cursor: pointer;
            }

            .login-card .form-check label {
                color: #FFFFFF;
                font-size: 0.8rem;
                cursor: pointer;
                margin: 0;
                text-transform: none;
            }

    .btn-login-neon {
        background: linear-gradient(135deg, #00CFFF, #7A00FF);
        color: #fff;
        border: none;
        border-radius: 50px;
        padding: 16px;
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        width: 100%;
        transition: all 0.3s ease;
        cursor: pointer;
        margin-top: 10px;
    }

        .btn-login-neon:hover {
            transform: translateY(-3px);
            box-shadow: 0 0 40px rgba(0,207,255,0.1);
        }

    .login-footer {
        text-align: center;
        margin-top: 25px;
        padding-top: 20px;
        border-top: 1px solid rgba(255,255,255,0.02);
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 6px;
    }

        .login-footer span {
            color: #FFFFFF;
            font-size: 0.85rem;
        }

        .login-footer a {
            color: #00CFFF;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.85rem;
            transition: all 0.3s ease;
        }

            .login-footer a:hover {
                color: #7A00FF;
                text-decoration: underline;
            }

    .credenciales-info {
        background: rgba(0,207,255,0.02);
        border: 1px solid rgba(0,207,255,0.02);
        border-radius: 12px;
        padding: 12px 15px;
        margin-bottom: 20px;
    }

        .credenciales-info small {
            color: #FFFFFF;
            font-size: 0.65rem;
            letter-spacing: 0.3px;
        }

        .credenciales-info strong {
            color: #FFFFFF;
        }

        .credenciales-info .admin {
            color: #00CFFF;
        }

        .credenciales-info .user {
            color: #7A00FF;
        }

    .login-card .alert {
        background: rgba(255,45,149,0.03);
        border: 1px solid rgba(255,45,149,0.04);
        color: #FF2D95;
        border-radius: 12px;
        padding: 12px 16px;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
    }
</style>

<div class="login-container">
    <div class="login-card" data-aos="fade-up">
        <div class="logo">
            <h1>NEO <span>STORE</span></h1>
            <p>Inicia sesión para continuar</p>
        </div>

        <div class="credenciales-info">
            <small>
                <span class="admin">●</span> <strong>Admin:</strong> admin@gmail.com / admin123 &nbsp;|&nbsp;
                <span class="user">●</span> <strong>Usuario:</strong> brayan@gmail.com / 123456
            </small>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                @TempData["Error"]
            </div>
        }

        <form method="post" action="/Account/Login">
            <div class="form-group">
                <label for="Email">Email</label>
                <input type="email" id="Email" name="Email" class="form-control" placeholder="tu@email.com" required />
            </div>

            <div class="form-group">
                <label for="Contrasena">Contraseña</label>
                <input type="password" id="Contrasena" name="Contrasena" class="form-control" placeholder="••••••••" required />
            </div>

            <div class="form-check">
                <input type="checkbox" id="Recordarme" name="Recordarme" value="true" />
                <label for="Recordarme">Recordarme</label>
            </div>

            <button type="submit" class="btn-login-neon">
                <i class="bi bi-box-arrow-in-right me-2"></i>Ingresar
            </button>
        </form>

        <div class="login-footer">
            <span>¿No tienes cuenta?</span>
            <a asp-action="Register">Regístrate</a>
        </div>
    </div>
</div>