@{
    ViewData["Title"] = "Registrarse - ROG Inventory";
}

<style>
    .register-rog-container {
        background: #0a0a0a;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
        font-family: 'Inter', sans-serif;
        position: relative;
        overflow: hidden;
    }

    .register-rog-container::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, rgba(255,0,68,0.05) 0%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
    }

    .register-rog-card {
        background: rgba(18, 18, 30, 0.8);
        border: 1px solid rgba(255,255,255,0.04);
        border-radius: 20px;
        padding: 50px 40px;
        max-width: 420px;
        width: 100%;
        backdrop-filter: blur(20px);
        position: relative;
        z-index: 1;
    }

    .register-rog-card .logo {
        text-align: center;
        margin-bottom: 35px;
    }

    .register-rog-card .logo h1 {
        font-size: 2.2rem;
        font-weight: 900;
        letter-spacing: -1px;
        color: #fff;
    }

    .register-rog-card .logo h1 span {
        background: linear-gradient(135deg, #ff0044, #ff6b35);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .register-rog-card .logo p {
        color: rgba(255,255,255,0.15);
        font-size: 0.85rem;
        letter-spacing: 1px;
    }

    .register-rog-card .form-group {
        margin-bottom: 20px;
    }

    .register-rog-card label {
        color: rgba(255,255,255,0.3);
        font-weight: 600;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 6px;
        display: block;
    }

    .register-rog-card .form-control {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 12px;
        color: #fff;
        padding: 14px 18px;
        width: 100%;
        transition: all 0.3s ease;
    }

    .register-rog-card .form-control:focus {
        outline: none;
        border-color: #ff0044;
        box-shadow: 0 0 0 4px rgba(255,0,68,0.05);
        background: rgba(255,255,255,0.06);
    }

    .register-rog-card .form-control::placeholder {
        color: rgba(255,255,255,0.08);
    }

    .btn-rog-primary {
        background: linear-gradient(135deg, #ff0044, #ff6b35);
        color: #fff;
        border: none;
        border-radius: 50px;
        padding: 16px;
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        width: 100%;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .btn-rog-primary:hover {
        transform: translateY(-3px);
        box-shadow: 0 0 40px rgba(255,0,68,0.2);
    }

    .register-rog-footer {
        text-align: center;
        margin-top: 25px;
        padding-top: 20px;
        border-top: 1px solid rgba(255,255,255,0.03);
    }

    .register-rog-footer a {
        color: rgba(255,255,255,0.15);
        text-decoration: none;
        transition: all 0.3s ease;
        font-size: 0.85rem;
    }

    .register-rog-footer a:hover {
        color: #ff0044;
    }
</style>

<div class="register-rog-container">
    <div class="register-rog-card">
        <div class="logo">
            <h1>Crear <span>Cuenta</span></h1>
            <p>Regístrate para comenzar</p>
        </div>

        <form method="post" action="/Account/Register">
            <div class="form-group">
                <label for="Nombre">Nombre completo</label>
                <input type="text" id="Nombre" name="Nombre" class="form-control" placeholder="Tu nombre" required />
            </div>

            <div class="form-group">
                <label for="Email">Email</label>
                <input type="email" id="Email" name="Email" class="form-control" placeholder="tu@email.com" required />
            </div>

            <div class="form-group">
                <label for="Contrasena">Contraseña</label>
                <input type="password" id="Contrasena" name="Contrasena" class="form-control" placeholder="Mínimo 6 caracteres" required />
            </div>

            <div class="form-group">
                <label for="ConfirmarContrasena">Confirmar contraseña</label>
                <input type="password" id="ConfirmarContrasena" name="ConfirmarContrasena" class="form-control" placeholder="Repite tu contraseña" required />
            </div>

            <button type="submit" class="btn-rog-primary">
                <i class="bi bi-person-plus me-2"></i>Registrarse
            </button>
        </form>

        <div class="register-rog-footer">
            <span style="color: rgba(255,255,255,0.08);">¿Ya tienes cuenta?</span>
            <a asp-action="Login">Inicia sesión</a>
        </div>
    </div>
</div>