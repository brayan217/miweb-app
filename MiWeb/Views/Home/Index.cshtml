@{
    ViewData["Title"] = "Tienda - Mi Inventario";
}

<!-- Estilos minimalistas -->
<style>
    /* Fondo limpio */
    .tienda-container {
        background: #0a0a0a;
        min-height: 100vh;
        padding: 0;
        margin: -20px -20px 0 -20px;
        color: #fff;
        font-family: 'Inter', sans-serif;
    }
    
    /* Banner sencillo */
    .hero-simple {
        padding: 60px 0 40px;
        text-align: center;
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    
    .hero-simple h1 {
        font-size: 3.5rem;
        font-weight: 800;
        letter-spacing: -2px;
        margin-bottom: 10px;
    }
    
    .hero-simple h1 span {
        background: linear-gradient(135deg, #ff0044, #ff6b35);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    
    .hero-simple p {
        color: rgba(255,255,255,0.5);
        font-size: 1.1rem;
        max-width: 500px;
        margin: 0 auto;
    }
    
    /* Navegación simple */
    .nav-simple {
        padding: 15px 0;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        margin-bottom: 40px;
    }
    
    .nav-simple a {
        color: rgba(255,255,255,0.4);
        text-decoration: none;
        margin: 0 20px;
        font-size: 0.85rem;
        font-weight: 500;
        letter-spacing: 0.5px;
        transition: color 0.3s;
        cursor: pointer;
    }
    
    .nav-simple a:hover,
    .nav-simple a.active {
        color: #fff;
    }
    
    /* Tarjetas de productos */
    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 30px;
        padding: 0 0 40px 0;
    }
    
    .product-item {
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 12px;
        padding: 20px;
        transition: all 0.3s ease;
        cursor: pointer;
    }
    
    .product-item:hover {
        background: rgba(255,255,255,0.05);
        border-color: rgba(255,0,68,0.2);
        transform: translateY(-5px);
    }
    
    .product-image {
        width: 100%;
        height: 180px;
        object-fit: contain;
        background: rgba(0,0,0,0.3);
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 15px;
    }
    
    .product-name {
        font-size: 1rem;
        font-weight: 600;
        margin: 0 0 5px 0;
        color: #fff;
    }
    
    .product-desc {
        font-size: 0.85rem;
        color: rgba(255,255,255,0.4);
        margin: 0 0 10px 0;
    }
    
    .product-price {
        font-size: 1.3rem;
        font-weight: 700;
        color: #ff0044;
    }
    
    .product-price .old {
        font-size: 0.9rem;
        color: rgba(255,255,255,0.2);
        text-decoration: line-through;
        font-weight: 400;
        margin-left: 10px;
    }
    
    /* Sección destacada */
    .featured-section {
        border-top: 1px solid rgba(255,255,255,0.05);
        border-bottom: 1px solid rgba(255,255,255,0.05);
        padding: 40px 0;
        margin: 20px 0;
    }
    
    .featured-section h3 {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 5px;
        color: #fff;
    }
    
    .featured-section h3 span {
        color: #ff0044;
    }
    
    .featured-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 20px;
        margin-top: 20px;
    }
    
    .featured-item {
        background: rgba(255,255,255,0.02);
        border-radius: 10px;
        padding: 15px;
        border: 1px solid rgba(255,255,255,0.03);
        transition: all 0.3s ease;
        cursor: pointer;
    }
    
    .featured-item:hover {
        background: rgba(255,255,255,0.04);
        border-color: rgba(255,0,68,0.1);
    }
    
    .featured-item img {
        width: 100%;
        height: 120px;
        object-fit: contain;
        background: rgba(0,0,0,0.3);
        border-radius: 6px;
        padding: 10px;
        margin-bottom: 10px;
    }
    
    .featured-item h6 {
        font-size: 0.9rem;
        font-weight: 600;
        margin: 0;
        color: #fff;
    }
    
    .featured-item small {
        color: rgba(255,255,255,0.3);
        font-size: 0.8rem;
    }
    
    /* Rewards */
    .rewards-box {
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 12px;
        padding: 25px 30px;
        transition: all 0.3s ease;
    }
    
    .rewards-box:hover {
        background: rgba(255,255,255,0.04);
        border-color: rgba(255,0,68,0.15);
    }
    
    .rewards-box h5 {
        color: #fff;
        font-weight: 700;
        margin: 0;
    }
    
    .rewards-box h5 span {
        color: #ff0044;
    }
    
    .rewards-box p {
        color: rgba(255,255,255,0.3);
        margin: 5px 0 0 0;
        font-size: 0.9rem;
    }
    
    .rewards-link {
        color: rgba(255,255,255,0.15);
        font-size: 0.85rem;
        text-decoration: none;
        transition: color 0.3s;
        display: inline-block;
    }
    
    .rewards-link:hover {
        color: #ff0044;
    }
    
    /* Footer */
    .footer-simple {
        padding: 30px 0;
        border-top: 1px solid rgba(255,255,255,0.05);
        margin-top: 20px;
    }
    
    .footer-simple .links a {
        color: rgba(255,255,255,0.3);
        text-decoration: none;
        font-size: 0.85rem;
        margin: 0 15px;
        transition: color 0.3s;
    }
    
    .footer-simple .links a:hover {
        color: #fff;
    }
    
    .footer-simple .copy {
        color: rgba(255,255,255,0.2);
        font-size: 0.8rem;
        margin-top: 15px;
    }
    
    /* Responsive */
    @@media (max-width: 768px) {
        .hero-simple h1 {
            font-size: 2.2rem;
        }
        
        .product-grid {
            grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
            gap: 15px;
        }
        
        .nav-simple a {
            margin: 0 10px;
            font-size: 0.75rem;
        }
        
        .featured-grid {
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        }
        
        .rewards-box {
            padding: 20px;
        }
    }
</style>

<!-- CONTENIDO PRINCIPAL -->
<div class="tienda-container">
    
    <!-- HERO - EN ESPAÑOL -->
    <div class="hero-simple">
        <div class="container">
            <h1>ROG <span>XREAL R</span></h1>
            <p>Amplifica tu victoria</p>
        </div>
    </div>
    
    <!-- NAVEGACIÓN - CON ENLACES FUNCIONALES -->
    <div class="nav-simple">
        <div class="container text-center">
            <a href="#" class="active">REPÚBLICA DE GAMERS</a>
            <a asp-controller="ProductosView" asp-action="Index">PRODUCTOS</a>
            <a href="#">INNOVACIÓN</a>
            <a href="#">SOPORTE</a>
        </div>
    </div>
    
    <!-- PRODUCTOS - CON ENLACES A DETALLE -->
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 style="font-weight: 700; color: #fff; margin: 0;">
                Productos
            </h4>
            <a asp-controller="ProductosView" asp-action="Index" 
               style="color: rgba(255,255,255,0.2); font-size: 0.85rem; text-decoration: none; transition: color 0.3s;">
                Ver todos →
            </a>
        </div>
        
        <div class="product-grid">
            <!-- Producto 1 - Enlace a detalle -->
            <a asp-controller="ProductosView" asp-action="Details" asp-route-id="1" 
               style="text-decoration: none; color: inherit; display: block;">
                <div class="product-item">
                    <img src="https://via.placeholder.com/300x180/1a0a2e/ff0044?text=ROG+Strix" 
                         class="product-image" alt="ROG Strix">
                    <h5 class="product-name">ASUS ROG Strix G18</h5>
                    <p class="product-desc">Laptop gamer</p>
                    <div class="product-price">
                        Bs22.000
                        <span class="old">Bs28.000</span>
                    </div>
                </div>
            </a>
            
            <!-- Producto 2 -->
            <a asp-controller="ProductosView" asp-action="Details" asp-route-id="2" 
               style="text-decoration: none; color: inherit; display: block;">
                <div class="product-item">
                    <img src="https://via.placeholder.com/300x180/0a0a0a/ff6b35?text=ROG+Phone" 
                         class="product-image" alt="ROG Phone">
                    <h5 class="product-name">ROG Phone 8</h5>
                    <p class="product-desc">Smartphone gamer</p>
                    <div class="product-price">
                        Bs15.500
                        <span class="old">Bs18.000</span>
                    </div>
                </div>
            </a>
            
            <!-- Producto 3 -->
            <a asp-controller="ProductosView" asp-action="Details" asp-route-id="3" 
               style="text-decoration: none; color: inherit; display: block;">
                <div class="product-item">
                    <img src="https://via.placeholder.com/300x180/0a0a0a/00d4ff?text=ROG+Monitor" 
                         class="product-image" alt="ROG Monitor">
                    <h5 class="product-name">ROG Swift OLED</h5>
                    <p class="product-desc">Monitor 4K 240Hz</p>
                    <div class="product-price">
                        Bs12.800
                        <span class="old">Bs16.000</span>
                    </div>
                </div>
            </a>
            
            <!-- Producto 4 -->
            <a asp-controller="ProductosView" asp-action="Details" asp-route-id="4" 
               style="text-decoration: none; color: inherit; display: block;">
                <div class="product-item">
                    <img src="https://via.placeholder.com/300x180/0a0a0a/ff0044?text=ROG+Keyboard" 
                         class="product-image" alt="ROG Keyboard">
                    <h5 class="product-name">ROG Azoth</h5>
                    <p class="product-desc">Teclado mecánico</p>
                    <div class="product-price">
                        Bs3.200
                        <span class="old">Bs4.500</span>
                    </div>
                </div>
            </a>
        </div>
    </div>
    
    <!-- SECCIÓN DESTACADA - CON ENLACES -->
    <div class="featured-section">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center">
                <h3 style="margin: 0;">Lo último en <span>tecnología gamer</span></h3>
                <a asp-controller="ProductosView" asp-action="Index" 
                   style="color: rgba(255,255,255,0.2); font-size: 0.85rem; text-decoration: none; transition: color 0.3s;">
                    Ver más →
                </a>
            </div>
            
            <div class="featured-grid">
                <a asp-controller="ProductosView" asp-action="Details" asp-route-id="5" 
                   style="text-decoration: none; color: inherit; display: block;">
                    <div class="featured-item">
                        <img src="https://via.placeholder.com/200x120/1a0a2e/ff0044?text=Producto" alt="Producto">
                        <h6>ROG Flow Z13</h6>
                        <small>Tablet gamer</small>
                    </div>
                </a>
                <a asp-controller="ProductosView" asp-action="Details" asp-route-id="6" 
                   style="text-decoration: none; color: inherit; display: block;">
                    <div class="featured-item">
                        <img src="https://via.placeholder.com/200x120/0a0a2e/ff6b35?text=Producto" alt="Producto">
                        <h6>ROG Delta II</h6>
                        <small>Auriculares</small>
                    </div>
                </a>
                <a asp-controller="ProductosView" asp-action="Details" asp-route-id="7" 
                   style="text-decoration: none; color: inherit; display: block;">
                    <div class="featured-item">
                        <img src="https://via.placeholder.com/200x120/1a0a2e/00d4ff?text=Producto" alt="Producto">
                        <h6>ROG Chakram X</h6>
                        <small>Mouse inalámbrico</small>
                    </div>
                </a>
                <a asp-controller="ProductosView" asp-action="Details" asp-route-id="8" 
                   style="text-decoration: none; color: inherit; display: block;">
                    <div class="featured-item">
                        <img src="https://via.placeholder.com/200x120/0a0a0a/ff0044?text=Producto" alt="Producto">
                        <h6>ROG Thor III</h6>
                        <small>Fuente de poder</small>
                    </div>
                </a>
            </div>
        </div>
    </div>
    
    <!-- REWARDS - CON ENLACE FUNCIONAL -->
    <div class="container py-4">
        <a asp-controller="Account" asp-action="Login" 
           style="text-decoration: none; color: inherit; display: block;">
            <div class="rewards-box">
                <div class="row align-items-center">
                    <div class="col-lg-9">
                        <h5>
                            <span>✦</span> Recompensas ROG Elite
                        </h5>
                        <p>
                            ¡Inicia sesión en el programa de recompensas ROG Elite ahora!
                        </p>
                    </div>
                    <div class="col-lg-3 text-end">
                        <span class="rewards-link">
                            Únete →
                        </span>
                    </div>
                </div>
            </div>
        </a>
    </div>
    
    <!-- FOOTER - CON ENLACES FUNCIONALES -->
    <div class="footer-simple">
        <div class="container">
            <div class="text-center links">
                <a asp-controller="ProductosView" asp-action="Index">Productos</a>
                <a href="#">Soporte</a>
                <a asp-controller="Home" asp-action="Index">Inicio</a>
            </div>
            <div class="text-center copy">
                © @DateTime.Now.Year — Tienda República de Gamers
            </div>
        </div>
    </div>
</div>