@model MiWeb.Models.Producto

@{
    ViewData["Title"] = "Crear Producto - NEO STORE";
}

<style>
    .create-rog-container {
        background: #0a0a0a;
        min-height: 100vh;
        padding: 40px 0;
        color: #fff;
        font-family: 'Inter', sans-serif;
    }

    .create-rog-card {
        background: rgba(18, 18, 30, 0.6);
        border: 1px solid rgba(255,255,255,0.03);
        border-radius: 16px;
        padding: 40px;
        max-width: 600px;
        margin: 0 auto;
        backdrop-filter: blur(10px);
    }

    .create-rog-card h1 {
        font-size: 2rem;
        font-weight: 900;
        letter-spacing: -1px;
        margin-bottom: 30px;
    }

    .create-rog-card h1 span {
        background: linear-gradient(135deg, #00CFFF, #7A00FF);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .create-rog-card .form-group {
        margin-bottom: 20px;
    }

    .create-rog-card label {
        color: rgba(255,255,255,0.3);
        font-weight: 600;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 6px;
        display: block;
    }

    .create-rog-card .form-control {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 12px;
        color: #fff;
        padding: 14px 18px;
        width: 100%;
        transition: all 0.3s ease;
    }

    .create-rog-card .form-control:focus {
        outline: none;
        border-color: #00CFFF;
        box-shadow: 0 0 0 4px rgba(0,207,255,0.05);
        background: rgba(255,255,255,0.06);
    }

    .create-rog-card .form-control::placeholder {
        color: rgba(255,255,255,0.08);
    }

    .btn-rog-primary {
        background: linear-gradient(135deg, #00CFFF, #7A00FF);
        color: #fff;
        border: none;
        border-radius: 50px;
        padding: 14px 40px;
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

    .btn-rog-primary:hover {
        transform: translateY(-3px);
        box-shadow: 0 0 30px rgba(0,207,255,0.2);
        color: #fff;
    }

    .btn-rog-outline {
        background: transparent;
        border: 1px solid rgba(255,255,255,0.06);
        color: rgba(255,255,255,0.3);
        border-radius: 50px;
        padding: 14px 40px;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

    .btn-rog-outline:hover {
        border-color: #00CFFF;
        color: #fff;
    }

    @@media (max-width: 768px) {
        .create-rog-card {
            padding: 20px;
        }
    }
</style>

<div class="create-rog-container">
    <div class="container">
        <div class="create-rog-card">
            <h1><i class="bi bi-plus-circle me-2" style="color: #00CFFF;"></i>Crear <span>Producto</span></h1>

            <form asp-action="Create" method="post">
                <div class="form-group">
                    <label asp-for="Nombre"></label>
                    <input asp-for="Nombre" class="form-control" placeholder="Nombre del producto" />
                    <span asp-validation-for="Nombre" class="text-danger" style="color: #ef476f; font-size: 0.75rem;"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Descripcion"></label>
                    <textarea asp-for="Descripcion" class="form-control" rows="3" placeholder="Descripción del producto"></textarea>
                    <span asp-validation-for="Descripcion" class="text-danger" style="color: #ef476f; font-size: 0.75rem;"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Precio"></label>
                    <input asp-for="Precio" class="form-control" type="number" step="0.01" placeholder="0.00" />
                    <span asp-validation-for="Precio" class="text-danger" style="color: #ef476f; font-size: 0.75rem;"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Cantidad"></label>
                    <input asp-for="Cantidad" class="form-control" type="number" placeholder="0" />
                    <span asp-validation-for="Cantidad" class="text-danger" style="color: #ef476f; font-size: 0.75rem;"></span>
                </div>

                <div class="d-flex gap-3 mt-4">
                    <a asp-action="Index" class="btn-rog-outline">
                        <i class="bi bi-arrow-left me-2"></i>Cancelar
                    </a>
                    <button type="submit" class="btn-rog-primary" style="flex: 1;">
                        <i class="bi bi-check-lg me-2"></i>Crear Producto
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}