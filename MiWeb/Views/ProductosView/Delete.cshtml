@model MiWeb.Models.Producto

@{
    ViewData["Title"] = "Eliminar Producto";
}

<style>
    .delete-container {
        background: #0a0a0a;
        min-height: 100vh;
        padding: 40px 0;
        color: #fff;
        font-family: 'Inter', sans-serif;
    }

    .delete-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 16px;
        padding: 40px;
        max-width: 500px;
        margin: 0 auto;
        text-align: center;
    }

    .delete-card .icon {
        font-size: 4rem;
        color: #ef476f;
        margin-bottom: 20px;
    }

    .delete-card h1 {
        font-size: 1.8rem;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .delete-card h1 span {
        color: #ef476f;
    }

    .delete-card p {
        color: rgba(255,255,255,0.4);
        margin-bottom: 30px;
    }

    .delete-card .product-info {
        background: rgba(255,255,255,0.03);
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 30px;
    }

    .delete-card .product-info .name {
        font-size: 1.2rem;
        font-weight: 700;
        color: #fff;
    }

    .delete-card .product-info .detail {
        color: rgba(255,255,255,0.3);
        font-size: 0.9rem;
        margin-top: 5px;
    }

    .btn-group-actions {
        display: flex;
        gap: 15px;
    }

    .btn-delete {
        background: #ef476f;
        color: #fff;
        border: none;
        border-radius: 50px;
        padding: 14px 40px;
        font-weight: 700;
        font-size: 1rem;
        transition: all 0.3s ease;
        cursor: pointer;
        flex: 1;
    }

    .btn-delete:hover {
        transform: translateY(-3px);
        box-shadow: 0 0 30px rgba(239,71,111,0.3);
        color: #fff;
    }

    .btn-cancel {
        background: transparent;
        border: 1px solid rgba(255,255,255,0.1);
        color: rgba(255,255,255,0.4);
        border-radius: 50px;
        padding: 14px 30px;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex: 1;
    }

    .btn-cancel:hover {
        border-color: rgba(255,255,255,0.2);
        color: #fff;
    }
</style>

<div class="delete-container">
    <div class="container">
        <div class="delete-card">
            <div class="icon">
                <i class="bi bi-exclamation-triangle"></i>
            </div>
            <h1>Eliminar <span>Producto</span></h1>
            <p>¿Estás seguro de que quieres eliminar este producto? Esta acción no se puede deshacer.</p>

            <div class="product-info">
                <div class="name">@Model.Nombre</div>
                <div class="detail">
                    Precio: Bs @Model.Precio.ToString("N0") | Stock: @Model.Cantidad unidades
                </div>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="btn-group-actions">
                    <a asp-action="Index" class="btn-cancel">
                        <i class="bi bi-arrow-left me-2"></i>Cancelar
                    </a>
                    <button type="submit" class="btn-delete">
                        <i class="bi bi-trash3 me-2"></i>Eliminar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>