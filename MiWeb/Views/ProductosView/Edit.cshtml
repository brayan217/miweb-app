@model LOGIN.Models.Producto

@{
    ViewData["Title"] = "Editar Producto";
}

<style>
    .edit-container {
        background: #0a0a0a;
        min-height: 100vh;
        padding: 40px 0;
        color: #fff;
        font-family: 'Inter', sans-serif;
    }

    .edit-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 16px;
        padding: 40px;
        max-width: 600px;
        margin: 0 auto;
    }

    .edit-card h1 {
        font-size: 1.8rem;
        font-weight: 800;
        margin-bottom: 30px;
    }

    .edit-card h1 span {
        color: #ff0044;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        color: rgba(255,255,255,0.6);
        font-weight: 600;
        font-size: 0.85rem;
        margin-bottom: 6px;
        display: block;
    }

    .form-group .form-control {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        color: #fff;
        padding: 12px 16px;
        width: 100%;
        transition: all 0.3s ease;
        font-size: 1rem;
    }

    .form-group .form-control:focus {
        outline: none;
        border-color: #ff0044;
        box-shadow: 0 0 0 4px rgba(255,0,68,0.1);
        background: rgba(255,255,255,0.08);
    }

    .form-group .form-control::placeholder {
        color: rgba(255,255,255,0.2);
    }

    .form-group .text-danger {
        color: #ff6b6b;
        font-size: 0.85rem;
        margin-top: 5px;
    }

    .btn-group-actions {
        display: flex;
        gap: 15px;
        margin-top: 30px;
    }

    .btn-submit {
        background: linear-gradient(135deg, #ff0044, #ff6b35);
        color: #fff;
        border: none;
        border-radius: 50px;
        padding: 14px 40px;
        font-weight: 700;
        font-size: 1rem;
        transition: all 0.3s ease;
        cursor: pointer;
        flex: 1;
    }

    .btn-submit:hover {
        transform: translateY(-3px);
        box-shadow: 0 0 30px rgba(255,0,68,0.3);
        color: #fff;
    }

    .btn-cancel {
        background: transparent;
        border: 1px solid rgba(255,255,255,0.1);
        color: rgba(255,255,255,0.4);
        border-radius: 50px;
        padding: 14px 30px;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .btn-cancel:hover {
        border-color: rgba(255,255,255,0.2);
        color: #fff;
    }
</style>

<div class="edit-container">
    <div class="container">
        <div class="edit-card">
            <h1><i class="bi bi-pencil-square me-2" style="color: #ff0044;"></i>Editar <span>Producto</span></h1>

            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="form-group">
                    <label asp-for="Nombre"></label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Descripcion"></label>
                    <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Descripcion" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Precio"></label>
                    <input asp-for="Precio" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Precio" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Cantidad"></label>
                    <input asp-for="Cantidad" class="form-control" type="number" />
                    <span asp-validation-for="Cantidad" class="text-danger"></span>
                </div>

                <div class="btn-group-actions">
                    <a asp-action="Index" class="btn-cancel">
                        <i class="bi bi-arrow-left me-2"></i>Cancelar
                    </a>
                    <button type="submit" class="btn-submit">
                        <i class="bi bi-check-lg me-2"></i>Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}