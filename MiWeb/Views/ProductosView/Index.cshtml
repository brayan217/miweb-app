@model IEnumerable<MiWeb.Models.Producto>

@{
    ViewData["Title"] = "Administrar Productos - ROG Inventory";
}

<style>
    .admin-rog-container {
        background: #0a0a0a;
        min-height: 100vh;
        padding: 40px 0;
        color: #fff;
        font-family: 'Inter', sans-serif;
    }

    .admin-rog-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        flex-wrap: wrap;
        gap: 15px;
    }

    .admin-rog-header h1 {
        font-size: 2rem;
        font-weight: 900;
        letter-spacing: -1px;
        margin: 0;
    }

    .admin-rog-header h1 span {
        background: linear-gradient(135deg, #ff0044, #ff6b35);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .admin-rog-header h1 i {
        color: #ff0044;
        margin-right: 10px;
    }

    .btn-rog-primary {
        background: linear-gradient(135deg, #ff0044, #ff6b35);
        color: #fff;
        border: none;
        border-radius: 50px;
        padding: 12px 30px;
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-rog-primary:hover {
        transform: translateY(-3px);
        box-shadow: 0 0 30px rgba(255,0,68,0.2);
        color: #fff;
    }

    .table-rog-container {
        background: rgba(18, 18, 30, 0.6);
        border: 1px solid rgba(255,255,255,0.03);
        border-radius: 16px;
        overflow: hidden;
        backdrop-filter: blur(10px);
    }

    .table-rog {
        color: rgba(255,255,255,0.8);
        margin: 0;
        border-collapse: collapse;
        width: 100%;
    }

    .table-rog thead {
        background: rgba(0,0,0,0.3);
        border-bottom: 1px solid rgba(255,255,255,0.03);
    }

    .table-rog thead th {
        color: rgba(255,255,255,0.2);
        font-weight: 700;
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        padding: 16px 20px;
        border: none;
    }

    .table-rog tbody td {
        padding: 16px 20px;
        border-bottom: 1px solid rgba(255,255,255,0.02);
        vertical-align: middle;
        font-size: 0.9rem;
        color: rgba(255,255,255,0.6);
    }

    .table-rog tbody tr:hover {
        background: rgba(255,255,255,0.02);
    }

    .table-rog tbody tr:last-child td {
        border-bottom: none;
    }

    .product-name-rog {
        font-weight: 600;
        color: #fff;
    }

    .product-desc-rog {
        color: rgba(255,255,255,0.15);
        font-size: 0.8rem;
        max-width: 200px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .product-price-rog {
        color: #ff0044;
        font-weight: 700;
    }

    .stock-badge-rog {
        padding: 4px 14px;
        border-radius: 50px;
        font-size: 0.55rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        display: inline-block;
        border: 1px solid transparent;
    }

    .stock-badge-rog.available {
        background: rgba(6, 214, 160, 0.08);
        color: #06d6a0;
        border-color: rgba(6, 214, 160, 0.06);
    }

    .stock-badge-rog.low {
        background: rgba(248, 150, 30, 0.08);
        color: #f8961e;
        border-color: rgba(248, 150, 30, 0.06);
    }

    .stock-badge-rog.empty {
        background: rgba(239, 71, 111, 0.08);
        color: #ef476f;
        border-color: rgba(239, 71, 111, 0.06);
    }

    .btn-rog-actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .btn-rog-action {
        padding: 6px 14px;
        border-radius: 50px;
        font-size: 0.6rem;
        font-weight: 700;
        border: 1px solid rgba(255,255,255,0.04);
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        background: rgba(0,0,0,0.3);
        color: rgba(255,255,255,0.2);
    }

    .btn-rog-action:hover {
        transform: translateY(-2px);
        background: rgba(0,0,0,0.5);
    }

    .btn-rog-action.details:hover {
        color: rgba(255,255,255,0.4);
        border-color: rgba(255,255,255,0.06);
    }

    .btn-rog-action.edit:hover {
        color: #4cc9f0;
        border-color: rgba(76, 201, 240, 0.1);
    }

    .btn-rog-action.delete:hover {
        color: #ef476f;
        border-color: rgba(239, 71, 111, 0.1);
    }

    .empty-rog-state {
        text-align: center;
        padding: 60px 20px;
    }

    .empty-rog-state i {
        font-size: 4rem;
        color: #FFFFFF;
        margin-bottom: 20px;
    }

    .empty-rog-state h3 {
        color: #FFFFFF;
        font-weight: 300;
    }

    .alert-rog-success {
        background: rgba(6, 214, 160, 0.04);
        border: 1px solid rgba(6, 214, 160, 0.06);
        border-radius: 12px;
        padding: 15px 20px;
        color: #06d6a0;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .alert-rog-error {
        background: rgba(239, 71, 111, 0.04);
        border: 1px solid rgba(239, 71, 111, 0.06);
        border-radius: 12px;
        padding: 15px 20px;
        color: #ef476f;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    @@media (max-width: 768px) {
        .admin-rog-header {
            flex-direction: column;
            align-items: stretch;
            text-align: center;
        }

        .table-rog-container {
            overflow-x: auto;
        }

        .btn-rog-actions {
            flex-direction: column;
            align-items: stretch;
        }

        .btn-rog-action {
            justify-content: center;
        }
    }
</style>

<div class="admin-rog-container">
    <div class="container">
        <div class="admin-rog-header">
            <h1><i class="bi bi-gear"></i>Administrar <span>Productos</span></h1>
            <a asp-action="Create" class="btn-rog-primary">
                <i class="bi bi-plus-lg"></i> Nuevo Producto
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert-rog-success">
                <i class="bi bi-check-circle-fill"></i>
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert-rog-error">
                <i class="bi bi-exclamation-triangle-fill"></i>
                @TempData["Error"]
            </div>
        }

        @if (Model != null && Model.Any())
        {
            <div class="table-rog-container">
                <table class="table-rog">
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th>Descripción</th>
                            <th>Precio</th>
                            <th>Stock</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var producto in Model)
                        {
                            <tr>
                                <td>
                                    <div class="product-name-rog">@producto.Nombre</div>
                                </td>
                                <td>
                                    <div class="product-desc-rog">@(producto.Descripcion ?? "Sin descripción")</div>
                                </td>
                                <td class="product-price-rog">Bs @producto.Precio.ToString("N0")</td>
                                <td>
                                    @{
                                        var stockClass = producto.Cantidad > 5 ? "available" : (producto.Cantidad > 0 ? "low" : "empty");
                                        var stockText = producto.Cantidad > 5 ? "Disponible" : (producto.Cantidad > 0 ? "Pocas unidades" : "Agotado");
                                    }
                                    <span class="stock-badge-rog @stockClass">● @stockText (@producto.Cantidad)</span>
                                </td>
                                <td class="text-end">
                                    <div class="btn-rog-actions">
                                        <a asp-action="Details" asp-route-id="@producto.Id" class="btn-rog-action details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@producto.Id" class="btn-rog-action edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@producto.Id" class="btn-rog-action delete">
                                            <i class="bi bi-trash3"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-rog-state">
                <i class="bi bi-box-seam"></i>
                <h3>No hay productos</h3>
                <p style="color: rgba(255,255,255,0.02);">Haz clic en "Nuevo Producto" para agregar tu primer producto</p>
            </div>
        }
    </div>
</div>