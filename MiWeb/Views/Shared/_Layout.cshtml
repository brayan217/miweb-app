<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Mi Inventario</title>

    <!-- Bootstrap 5.3 (moderno) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Bootstrap Icons (para íconos bonitos) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- Font Awesome (más iconos) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- Fuente moderna Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">

    <!-- TU CSS PERSONALIZADO (con el código profesional) -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Estilos adicionales para mejorar la experiencia -->
    <style>
            /* Ajustes rápidos para el layout */
            body {
                display: flex;
                flex-direction: column;
                min-height: 100vh;
            }

            main {
                flex: 1;
            }

            /* Mejora para el footer */
            footer {
                margin-top: auto;
            }

            /* Animación para los mensajes de alerta */
            .alert {
                animation: slideDown 0.5s ease-out;
            }

            @@keyframes slideDown {
                from {
                    opacity: 0;
                    transform: translateY(-20px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }
    </style>
</head>
<body>
    <header>
        <!-- NAVBAR MEJORADA CON EFECTOS PROFESIONALES -->
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-box-seam me-2"></i>Mi Inventario
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="ProductosView" asp-action="Index">
                                <i class="bi bi-grid-3x3-gap-fill me-1"></i>Productos
                            </a>
                        </li>
                        <!-- NUEVO ENLACE: Tienda (e-commerce) -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Tienda" asp-action="Index">
                                <i class="bi bi-shop me-1"></i>Tienda
                            </a>
                        </li>
                        @if (!string.IsNullOrEmpty(Context.Session.GetString("UsuarioId")))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right me-1"></i>Cerrar Sesión
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Iniciar Sesión
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">
                                    <i class="bi bi-person-plus me-1"></i>Registrarse
                                </a>
                            </li>
                        }
                    </ul>
                    @if (!string.IsNullOrEmpty(Context.Session.GetString("UsuarioId")))
                    {
                        <div class="d-flex align-items-center">
                            <span class="navbar-text text-white-50 me-3">
                                <i class="bi bi-person-circle me-1"></i>@Context.Session.GetString("UsuarioNombre")
                            </span>
                            <!-- Badge de notificaciones (ejemplo) -->
                            <span class="badge bg-primary rounded-pill">
                                <i class="bi bi-bell"></i> 3
                            </span>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>

    <!-- CONTENEDOR PRINCIPAL CON MEJORES MÁRGENES -->
    <div class="container mt-4">
        <!-- Mostrar mensajes de éxito/error (TempData) -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER MODERNO -->
    <footer class="footer">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-md-start">
                    <small>
                        <i class="bi bi-c-circle me-1"></i> @DateTime.Now.Year -
                        <strong>Mi Inventario Moderno</strong>
                    </small>
                </div>
                <div class="col-md-6 text-md-end">
                    <a href="#" class="text-white-50 me-3">
                        <i class="bi bi-facebook"></i>
                    </a>
                    <a href="#" class="text-white-50 me-3">
                        <i class="bi bi-twitter-x"></i>
                    </a>
                    <a href="#" class="text-white-50 me-3">
                        <i class="bi bi-instagram"></i>
                    </a>
                    <a href="#" class="text-white-50">
                        <i class="bi bi-github"></i>
                    </a>
                </div>
            </div>
        </div>
    </footer>

    <!-- SCRIPTS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Script para cerrar alertas automáticamente -->
    <script>
            // Cerrar alertas después de 5 segundos
            document.addEventListener('DOMContentLoaded', function() {
                setTimeout(function() {
                    const alerts = document.querySelectorAll('.alert');
                    alerts.forEach(function(alert) {
                        const closeBtn = alert.querySelector('.btn-close');
                        if (closeBtn) {
                            closeBtn.click();
                        }
                    });
                }, 5000);
            });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>