<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NEO STORE</title>

    <!-- ⭐ PWA -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#00CFFF" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <!-- ⭐ BOOTSTRAP 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- ⭐ ICONOS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- ⭐ FUENTE INTER + ORBITRON -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800;14..32,900&family=Orbitron:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

    <!-- ⭐ ANIMACIONES -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />

    <!-- ⭐ CSS PERSONALIZADO -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ⭐ PARTICULAS DE FONDO -->
    <div id="particles-js"></div>

    <!-- ⭐ NAVBAR FUTURISTA -->
    <nav class="navbar navbar-expand-lg navbar-dark" id="mainNavbar">
        <div class="container">
            <!-- ⭐ LOGO 3D -->
            <a class="navbar-brand" asp-controller="Home" asp-action="Index" id="logo3d">
                <div class="logo-container">
                    <div class="logo-3d">
                        <span class="logo-text">NEO</span>
                        <span class="logo-text logo-glow">STORE</span>
                    </div>
                    <div class="logo-line"></div>
                </div>
            </a>

            <button class="navbar-toggler neon-border" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Tienda" asp-action="Index">
                            <i class="bi bi-shop"></i>
                            <span>Tienda</span>
                            <span class="nav-link-glow"></span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Tienda" asp-action="Carrito">
                            <i class="bi bi-cart3"></i>
                            <span>Carrito</span>
                            <span class="nav-link-glow"></span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="ProductosView" asp-action="Index">
                            <i class="bi bi-gear"></i>
                            <span>Administrar</span>
                            <span class="nav-link-glow"></span>
                        </a>
                    </li>
                </ul>

                <!-- ⭐ BARRA DE BÚSQUEDA FUTURISTA -->
                <form class="search-form" asp-controller="Tienda" asp-action="Index" method="get">
                    <input type="text" name="searchString" class="search-input" placeholder="🔍 Buscar..." />
                    <button type="submit" class="search-btn">
                        <i class="bi bi-search"></i>
                    </button>
                </form>

                <!-- ⭐ USUARIO -->
                @if (!string.IsNullOrEmpty(Context.Session.GetString("UsuarioId")))
                {
                    <div class="user-area">
                        <div class="user-avatar">
                            <i class="bi bi-person-circle"></i>
                            <span class="user-status"></span>
                        </div>
                        <span class="user-name">@Context.Session.GetString("UsuarioNombre")</span>
                        <a asp-controller="Account" asp-action="Logout" class="btn-logout">
                            <i class="bi bi-box-arrow-right"></i>
                        </a>
                    </div>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn-login-neon">
                        <i class="bi bi-box-arrow-in-right"></i> Iniciar
                    </a>
                }
            </div>
        </div>
    </nav>

    <!-- ⭐ CONTENIDO PRINCIPAL -->
    <div class="container-fluid" style="padding: 0;">
        @RenderBody()
    </div>

    <!-- ⭐ FOOTER FUTURISTA -->
    <footer class="footer-neon">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="footer-brand">
                        <div class="logo-3d">
                            <span class="logo-text">NEO</span>
                            <span class="logo-text logo-glow">STORE</span>
                        </div>
                        <p class="footer-desc">La tienda gamer del futuro</p>
                        <div class="social-icons">
                            <a href="#"><i class="bi bi-twitter-x"></i></a>
                            <a href="#"><i class="bi bi-instagram"></i></a>
                            <a href="#"><i class="bi bi-youtube"></i></a>
                            <a href="#"><i class="bi bi-discord"></i></a>
                            <a href="#"><i class="bi bi-tiktok"></i></a>
                        </div>
                    </div>
                </div>
                <div class="col-lg-2 col-6">
                    <h6>Productos</h6>
                    <ul>
                        <li><a href="#">Laptops</a></li>
                        <li><a href="#">PC Gamer</a></li>
                        <li><a href="#">Monitores</a></li>
                        <li><a href="#">Componentes</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-6">
                    <h6>Soporte</h6>
                    <ul>
                        <li><a href="#">Ayuda</a></li>
                        <li><a href="#">Contacto</a></li>
                        <li><a href="#">FAQ</a></li>
                        <li><a href="#">Garantía</a></li>
                    </ul>
                </div>
                <div class="col-lg-4">
                    <h6>Newsletter</h6>
                    <p class="newsletter-text">Recibe ofertas exclusivas</p>
                    <div class="newsletter-form">
                        <input type="email" placeholder="tu@email.com" />
                        <button><i class="bi bi-send"></i></button>
                    </div>
                    <div class="payment-methods">
                        <i class="bi bi-credit-card"></i>
                        <i class="bi bi-paypal"></i>
                        <i class="bi bi-bank"></i>
                        <span>+ todos los métodos</span>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p>© @DateTime.Now.Year — <span class="neon-text">NEO STORE</span>. Todos los derechos reservados.</p>
            </div>
        </div>
    </footer>

    <!-- ⭐ SCRIPTS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/particles.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>