<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Tienda</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark" style="background: rgba(10,10,10,0.95); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(255,255,255,0.04); padding: 0.8rem 0; position: sticky; top: 0; z-index: 1050;">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index" style="color: #ff0044 !important; font-weight: 800; font-size: 1.3rem; letter-spacing: -0.5px;">
                <i class="bi bi-box-seam me-2"></i>Mi Inventario
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#tiendaNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="tiendaNavbar">
                <ul class="navbar-nav me-auto">
                    <!-- ⭐ TIENDA (página pública) -->
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Tienda" asp-action="Index" style="color: rgba(255,255,255,0.4) !important; font-weight: 600; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; transition: color 0.3s;">
                            <i class="bi bi-shop me-1"></i>Tienda
                        </a>
                    </li>
                    <!-- ⭐ CARRITO -->
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Tienda" asp-action="Carrito" style="color: rgba(255,255,255,0.4) !important; font-weight: 600; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; transition: color 0.3s;">
                            <i class="bi bi-cart3 me-1"></i>Carrito
                        </a>
                    </li>
                    <!-- ⭐ ADMINISTRAR PRODUCTOS (CRUD) -->
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="ProductosView" asp-action="Index" style="color: rgba(255,255,255,0.4) !important; font-weight: 600; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; transition: color 0.3s;">
                            <i class="bi bi-gear me-1"></i>Administrar
                        </a>
                    </li>
                </ul>
                @if (!string.IsNullOrEmpty(Context.Session.GetString("UsuarioId")))
                {
                    <div class="d-flex align-items-center gap-3">
                        <span class="text-white-50" style="font-size: 0.75rem; letter-spacing: 0.5px; font-weight: 300; opacity: 0.3;">
                            <i class="bi bi-person-circle me-1"></i>@Context.Session.GetString("UsuarioNombre")
                        </span>
                        <a asp-controller="Account" asp-action="Logout" class="btn btn-sm" style="background: transparent; border: 1px solid rgba(255,255,255,0.04); color: rgba(255,255,255,0.2); border-radius: 50px; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1px; padding: 6px 18px; transition: all 0.3s;">
                            <i class="bi bi-box-arrow-right me-1"></i>Cerrar Sesión
                        </a>
                    </div>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-sm" style="background: linear-gradient(135deg, #ff0044, #ff6b35); color: #fff; border: none; border-radius: 50px; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1px; padding: 6px 18px; transition: all 0.3s;">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Iniciar Sesión
                    </a>
                }
            </div>
        </div>
    </nav>

    <div class="container-fluid" style="padding: 0;">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>