@model List<MiWeb.Models.CarritoItem>
@{
    ViewData["Title"] = "Checkout - NEO STORE";
    var total = ViewBag.Total as decimal? ?? 0;
}

<style>
    .checkout-rog-container {
        background: #0a0a0a;
        min-height: 100vh;
        padding: 40px 0;
        color: #FFFFFF;
        font-family: 'Inter', sans-serif;
    }

    .checkout-rog-container h1 {
        font-size: 2.5rem;
        font-weight: 900;
        letter-spacing: -1px;
        color: #FFFFFF;
    }

    .checkout-rog-container h1 span {
        background: linear-gradient(135deg, #00CFFF, #7A00FF);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .checkout-rog-card {
        background: rgba(18, 18, 30, 0.6);
        border: 1px solid rgba(255,255,255,0.03);
        border-radius: 16px;
        padding: 30px;
        margin-bottom: 20px;
        backdrop-filter: blur(10px);
        transition: all 0.3s ease;
    }

    .checkout-rog-card:hover {
        border-color: rgba(0,207,255,0.1);
    }

    .checkout-rog-card h5 {
        color: #FFFFFF;
        font-weight: 700;
        margin-bottom: 20px;
    }

    .checkout-rog-card h5 i {
        color: #00CFFF;
        margin-right: 10px;
    }

    .checkout-rog-card label {
        color: #FFFFFF;
        font-weight: 600;
        font-size: 0.85rem;
        margin-bottom: 6px;
        display: block;
    }

    .checkout-rog-card .form-control,
    .checkout-rog-card select {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 12px;
        color: #FFFFFF;
        padding: 14px 18px;
        width: 100%;
        transition: all 0.3s ease;
    }

    .checkout-rog-card .form-control:focus,
    .checkout-rog-card select:focus {
        outline: none;
        border-color: #00CFFF;
        box-shadow: 0 0 0 4px rgba(0,207,255,0.05);
        background: rgba(255,255,255,0.06);
    }

    .checkout-rog-card .form-control::placeholder {
        color: rgba(255,255,255,0.2);
    }

    .checkout-rog-card select option {
        background: #1a1a2e;
        color: #FFFFFF;
    }

    .checkout-rog-card .form-control.is-invalid {
        border-color: #ff4757;
        box-shadow: 0 0 0 4px rgba(255,71,87,0.1);
    }

    .checkout-rog-card .text-danger {
        color: #ff4757 !important;
        font-size: 0.8rem;
        margin-top: 5px;
        display: block;
    }

    .alert-rog-error {
        background: rgba(255,71,87,0.1);
        border: 1px solid rgba(255,71,87,0.2);
        border-radius: 12px;
        color: #ff4757;
        padding: 15px 20px;
        margin-bottom: 20px;
    }

    .alert-rog-error i {
        margin-right: 10px;
    }

    .checkout-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 0;
        border-bottom: 1px solid rgba(255,255,255,0.03);
    }

    .checkout-item:last-child {
        border-bottom: none;
    }

    .checkout-item .info {
        flex: 1;
    }

    .checkout-item .info .nombre {
        color: #FFFFFF;
        font-weight: 600;
    }

    .checkout-item .info .detalle {
        color: rgba(255,255,255,0.5);
        font-size: 0.85rem;
    }

    .checkout-item .cantidad {
        color: rgba(255,255,255,0.3);
        font-size: 0.85rem;
        margin: 0 15px;
    }

    .checkout-item .precio {
        color: #00CFFF;
        font-weight: 700;
        font-size: 1.1rem;
    }

    .checkout-rog-total {
        text-align: right;
        padding: 20px 0;
        border-top: 1px solid rgba(255,255,255,0.03);
        margin-top: 20px;
    }

    .checkout-rog-total .label {
        color: #FFFFFF;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .checkout-rog-total .precio {
        color: #00CFFF;
        font-size: 2rem;
        font-weight: 900;
    }

    .btn-rog-primary {
        background: linear-gradient(135deg, #00CFFF, #7A00FF);
        color: #FFFFFF;
        border: none;
        border-radius: 50px;
        padding: 16px 50px;
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        transition: all 0.3s ease;
        cursor: pointer;
        flex: 1;
        min-width: 200px;
    }

    .btn-rog-primary:hover:not(:disabled) {
        transform: translateY(-3px);
        box-shadow: 0 0 40px rgba(0,207,255,0.2);
        color: #FFFFFF;
    }

    .btn-rog-primary:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none !important;
    }

    .btn-rog-outline {
        background: transparent;
        border: 1px solid rgba(255,255,255,0.06);
        color: #FFFFFF;
        border-radius: 50px;
        padding: 14px 40px;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex: 1;
        min-width: 150px;
    }

    .btn-rog-outline:hover {
        border-color: #00CFFF;
        color: #FFFFFF;
        text-decoration: none;
    }

    .botones-container {
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
    }

    @@media (max-width: 576px) {
        .botones-container {
            flex-direction: column;
        }
        .botones-container .btn-rog-primary,
        .botones-container .btn-rog-outline {
            flex: none;
            width: 100%;
        }
    }

    .spinner-rog {
        display: inline-block;
        width: 20px;
        height: 20px;
        border: 2px solid rgba(255,255,255,0.1);
        border-top-color: #FFFFFF;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin-right: 10px;
        vertical-align: middle;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }
</style>

<div class="checkout-rog-container">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <h1 class="mb-4">Finalizar <span>Compra</span></h1>

                @if (TempData["Error"] != null)
                {
                    <div class="alert-rog-error">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        @TempData["Error"]
                    </div>
                }

                <form asp-controller="Tienda" asp-action="ProcesarPago" method="post" id="checkoutForm" novalidate>
                    @Html.AntiForgeryToken()

                    <!-- ⭐ NOMBRE COMPLETO ⭐ -->
                    <div class="checkout-rog-card">
                        <h5><i class="bi bi-person"></i>Datos personales</h5>
                        <div class="mb-3">
                            <label>Nombre completo</label>
                            <input type="text" 
                                   name="nombre" 
                                   id="nombre"
                                   class="form-control" 
                                   placeholder="Ej: Juan Pérez" 
                                   required />
                            <span class="text-danger" id="nombreError"></span>
                        </div>
                    </div>

                    <!-- ⭐ DIRECCIÓN DE ENVÍO ⭐ -->
                    <div class="checkout-rog-card">
                        <h5><i class="bi bi-geo-alt"></i>Dirección de envío</h5>
                        <div class="mb-3">
                            <label>Dirección completa</label>
                            <input type="text" 
                                   name="direccion" 
                                   id="direccion"
                                   class="form-control" 
                                   placeholder="Calle, número, ciudad, departamento" 
                                   required />
                            <span class="text-danger" id="direccionError"></span>
                        </div>
                    </div>

                    <!-- ⭐ MÉTODO DE PAGO ⭐ -->
                    <div class="checkout-rog-card">
                        <h5><i class="bi bi-credit-card"></i>Método de pago</h5>
                        <div class="mb-3">
                            <label>Selecciona un método</label>
                            <select name="metodoPago" id="metodoPago" class="form-control" required>
                                <option value="">Selecciona...</option>
                                <option value="Tarjeta de Crédito">💳 Tarjeta de Crédito</option>
                                <option value="Tarjeta de Débito">💳 Tarjeta de Débito</option>
                                <option value="Transferencia Bancaria">🏦 Transferencia Bancaria</option>
                                <option value="Pago en Efectivo">💵 Pago en Efectivo</option>
                            </select>
                            <span class="text-danger" id="metodoError"></span>
                        </div>
                    </div>

                    <!-- ⭐ RESUMEN DEL PEDIDO ⭐ -->
                    <div class="checkout-rog-card">
                        <h5><i class="bi bi-receipt"></i>Resumen del pedido</h5>
                        
                        @if (Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <div class="checkout-item">
                                    <div class="info">
                                        <div class="nombre">@item.Producto?.Nombre</div>
                                        <div class="detalle">@item.Producto?.Descripcion</div>
                                    </div>
                                    <div class="cantidad">× @item.Cantidad</div>
                                    <div class="precio">Bs @(item.Producto?.Precio.ToString("N0") ?? "0")</div>
                                </div>
                            }
                        }
                        else
                        {
                            <p style="color: rgba(255,255,255,0.3);">No hay productos en el carrito</p>
                        }

                        <div class="checkout-rog-total">
                            <div>
                                <span class="label">Total a pagar</span>
                                <div class="precio">Bs @total.ToString("N0")</div>
                            </div>
                        </div>
                    </div>

                    <div class="botones-container">
                        <a asp-controller="Tienda" asp-action="Carrito" class="btn-rog-outline">
                            <i class="bi bi-arrow-left me-2"></i>Volver al carrito
                        </a>
                        <button type="submit" class="btn-rog-primary" id="confirmarBtn">
                            <i class="bi bi-check-circle me-2"></i>Confirmar pedido
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const form = document.getElementById('checkoutForm');
        const btn = document.getElementById('confirmarBtn');
        const nombreInput = document.getElementById('nombre');
        const direccionInput = document.getElementById('direccion');
        const metodoSelect = document.getElementById('metodoPago');
        const nombreError = document.getElementById('nombreError');
        const direccionError = document.getElementById('direccionError');
        const metodoError = document.getElementById('metodoError');

        // Validación en tiempo real
        nombreInput.addEventListener('blur', function() {
            if (!this.value.trim()) {
                this.classList.add('is-invalid');
                nombreError.textContent = 'El nombre es obligatorio';
            } else {
                this.classList.remove('is-invalid');
                nombreError.textContent = '';
            }
        });

        nombreInput.addEventListener('input', function() {
            if (this.value.trim()) {
                this.classList.remove('is-invalid');
                nombreError.textContent = '';
            }
        });

        direccionInput.addEventListener('blur', function() {
            if (!this.value.trim()) {
                this.classList.add('is-invalid');
                direccionError.textContent = 'La dirección es obligatoria';
            } else {
                this.classList.remove('is-invalid');
                direccionError.textContent = '';
            }
        });

        direccionInput.addEventListener('input', function() {
            if (this.value.trim()) {
                this.classList.remove('is-invalid');
                direccionError.textContent = '';
            }
        });

        metodoSelect.addEventListener('change', function() {
            if (this.value) {
                this.classList.remove('is-invalid');
                metodoError.textContent = '';
            }
        });

        // Submit del formulario
        form.addEventListener('submit', function(e) {
            const nombre = nombreInput.value.trim();
            if (!nombre) {
                e.preventDefault();
                nombreInput.classList.add('is-invalid');
                nombreError.textContent = 'El nombre es obligatorio';
                nombreInput.focus();
                return false;
            }

            const direccion = direccionInput.value.trim();
            if (!direccion) {
                e.preventDefault();
                direccionInput.classList.add('is-invalid');
                direccionError.textContent = 'La dirección es obligatoria';
                direccionInput.focus();
                return false;
            }

            const metodo = metodoSelect.value;
            if (!metodo) {
                e.preventDefault();
                metodoSelect.classList.add('is-invalid');
                metodoError.textContent = 'Debes seleccionar un método de pago';
                metodoSelect.focus();
                return false;
            }

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-rog"></span>Procesando pago...';
            btn.style.opacity = '0.7';

            return true;
        });
    });
</script>