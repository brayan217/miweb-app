@{
    ViewData["Title"] = "Checkout - NEO STORE";
    var total = ViewBag.Total as decimal? ?? 0;
}

<style>
    .checkout-rog-container {
        background: #0a0a0a;
        min-height: 100vh;
        padding: 40px 0;
        color: #fff;
        font-family: 'Inter', sans-serif;
    }

    .checkout-rog-container h1 {
        font-size: 2.5rem;
        font-weight: 900;
        letter-spacing: -1px;
    }

    .checkout-rog-container h1 span {
        background: linear-gradient(135deg, #00CFFF, #7A00FF);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .checkout-rog-card {
        background: rgba(18, 18, 30, 0.6);
        border: 1px solid rgba(255,255,255,0.03);
        border-radius: 16px;
        padding: 30px;
        margin-bottom: 20px;
        backdrop-filter: blur(10px);
    }

    .checkout-rog-card h5 {
        color: #fff;
        font-weight: 700;
        margin-bottom: 20px;
    }

    .checkout-rog-card h5 i {
        color: #00CFFF;
        margin-right: 10px;
    }

    .checkout-rog-card label {
        color: #FFFFFF;
        font-weight: 600;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 6px;
        display: block;
    }

    .checkout-rog-card .form-control,
    .checkout-rog-card select {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 12px;
        color: #fff;
        padding: 14px 18px;
        width: 100%;
        transition: all 0.3s ease;
    }

    .checkout-rog-card .form-control:focus,
    .checkout-rog-card select:focus {
        outline: none;
        border-color: #00CFFF;
        box-shadow: 0 0 0 4px rgba(0,207,255,0.05);
        background: rgba(255,255,255,0.06);
    }

    .checkout-rog-card .form-control::placeholder {
        color: #FFFFFF;
    }

    .checkout-rog-card select option {
        background: #1a1a2e;
        color: #fff;
    }

    .checkout-rog-total {
        text-align: right;
        padding: 20px 0;
        border-top: 1px solid rgba(255,255,255,0.03);
        margin-top: 20px;
    }

    .checkout-rog-total .label {
        color: #FFFFFF;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .checkout-rog-total .precio {
        color: #00CFFF;
        font-size: 2rem;
        font-weight: 900;
    }

    .btn-rog-primary {
        background: linear-gradient(135deg, #00CFFF, #7A00FF);
        color: #fff;
        border: none;
        border-radius: 50px;
        padding: 16px 50px;
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        transition: all 0.3s ease;
        cursor: pointer;
        width: 100%;
    }

    .btn-rog-primary:hover {
        transform: translateY(-3px);
        box-shadow: 0 0 40px rgba(0,207,255,0.2);
        color: #fff;
    }

    .btn-rog-primary:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .btn-rog-outline {
        background: transparent;
        border: 1px solid rgba(255,255,255,0.06);
        color: #FFFFFF;
        border-radius: 50px;
        padding: 14px 40px;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

    .btn-rog-outline:hover {
        border-color: #00CFFF;
        color: #fff;
    }

    @@media (max-width: 768px) {
        .checkout-rog-total {
            text-align: center;
        }
    }
</style>

<div class="checkout-rog-container">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <h1 class="mb-4">Finalizar <span>Compra</span></h1>

                <form asp-controller="Tienda" asp-action="ConfirmarPedido" method="post" id="checkoutForm">
                    <div class="checkout-rog-card">
                        <h5><i class="bi bi-geo-alt"></i>Dirección de envío</h5>
                        <div class="mb-3">
                            <label>Dirección completa</label>
                            <input type="text" name="direccion" class="form-control" placeholder="Calle, número, ciudad, departamento" required />
                        </div>
                    </div>

                    <div class="checkout-rog-card">
                        <h5><i class="bi bi-credit-card"></i>Método de pago</h5>
                        <div class="mb-3">
                            <label>Selecciona un método</label>
                            <select name="metodoPago" class="form-control" required>
                                <option value="">Selecciona...</option>
                                <option value="Tarjeta de Crédito">Tarjeta de Crédito</option>
                                <option value="Tarjeta de Débito">Tarjeta de Débito</option>
                                <option value="Transferencia Bancaria">Transferencia Bancaria</option>
                                <option value="Pago en Efectivo">Pago en Efectivo (contra entrega)</option>
                            </select>
                        </div>
                    </div>

                    <div class="checkout-rog-card">
                        <h5><i class="bi bi-receipt"></i>Resumen del pedido</h5>
                        <div class="checkout-rog-total">
                            <div>
                                <span class="label">Total a pagar</span>
                                <div class="precio">Bs @total.ToString("N0")</div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-3 flex-wrap">
                        <a asp-controller="Tienda" asp-action="Carrito" class="btn-rog-outline">
                            <i class="bi bi-arrow-left me-2"></i>Volver al carrito
                        </a>
                        <button type="submit" class="btn-rog-primary" id="confirmarBtn">
                            <i class="bi bi-check-circle me-2"></i>Confirmar pedido
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('confirmarBtn').addEventListener('click', function(e) {
        const form = document.getElementById('checkoutForm');
        if (!form.checkValidity()) {
            e.preventDefault();
            form.reportValidity();
            return;
        }
        if (!confirm('¿Confirmar tu pedido?')) {
            e.preventDefault();
        } else {
            this.disabled = true;
            this.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Procesando...';
        }
    });
</script>