@model MiWeb.Models.ConfirmacionViewModel

    ViewData["Title"] = "¡Compra Confirmada! - NEO STORE";
    Layout = "~/Views/Shared/LayoutTienda.cshtml";
}

<style>
    .confirm-rog-container {
        background: #0a0a0a;
        min-height: 100vh;
        padding: 60px 0;
        color: #fff;
        font-family: 'Inter', sans-serif;
    }

    .confirm-rog-card {
        background: rgba(18, 18, 30, 0.6);
        border: 1px solid rgba(255,255,255,0.03);
        border-radius: 20px;
        padding: 50px;
        backdrop-filter: blur(10px);
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .confirm-rog-card::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle at 30% 30%, rgba(0,207,255,0.03), transparent 70%);
        pointer-events: none;
    }

    .confirm-icon {
        width: 100px;
        height: 100px;
        background: linear-gradient(135deg, rgba(0,207,255,0.1), rgba(122,0,255,0.1));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 30px;
        border: 1px solid rgba(0,207,255,0.1);
        animation: pulse 2s ease-in-out infinite;
    }

    @@keyframes pulse {
        0% { transform: scale(1); }
        50% { transform: scale(1.05); }
        100% { transform: scale(1); }
    }

    .confirm-icon i {
        font-size: 4rem;
        color: #00CFFF;
    }

    .confirm-rog-card h1 {
        font-size: 2.8rem;
        font-weight: 900;
        background: linear-gradient(135deg, #00CFFF, #7A00FF);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 10px;
    }

    .confirm-rog-card .subtitle {
        color: #fff;
        font-size: 1.1rem;
        margin-bottom: 30px;
    }

    .confirm-rog-card .pedido-info {
        background: rgba(255,255,255,0.03);
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 30px;
        border: 1px solid rgba(255,255,255,0.03);
    }

    .confirm-rog-card .pedido-info .ref {
        color: #00CFFF;
        font-weight: 700;
        font-size: 1.2rem;
    }

    .confirm-rog-card .pedido-info .ref small {
        color: #fff;
        font-size: 0.8rem;
        display: block;
        margin-top: 5px;
    }

    .confirm-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
        margin: 30px 0;
    }

    .confirm-grid .item {
        background: rgba(255,255,255,0.02);
        border-radius: 12px;
        padding: 15px;
        border: 1px solid rgba(255,255,255,0.02);
    }

    .confirm-grid .item .label {
        color: #fff;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .confirm-grid .item .value {
        color: #fff;
        font-weight: 700;
        font-size: 1.1rem;
        margin-top: 5px;
    }

    .confirm-grid .item .value.total {
        color: #00CFFF;
        font-size: 1.5rem;
    }

    .confirm-rog-card .detalles-envio {
        text-align: left;
        background: rgba(255,255,255,0.02);
        border-radius: 12px;
        padding: 20px;
        margin: 20px 0 30px;
        border: 1px solid rgba(255,255,255,0.02);
    }

    .confirm-rog-card .detalles-envio .row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
    }

    .confirm-rog-card .detalles-envio .label {
        color: #fff;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .confirm-rog-card .detalles-envio .value {
        color: #fff;
        font-weight: 600;
    }

    .btn-rog-primary {
        background: linear-gradient(135deg, #00CFFF, #7A00FF);
        color: #fff;
        border: none;
        border-radius: 50px;
        padding: 16px 40px;
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
        margin: 5px;
    }

    .btn-rog-primary:hover {
        transform: translateY(-3px);
        box-shadow: 0 0 40px rgba(0,207,255,0.2);
        color: #fff;
        text-decoration: none;
    }

    .btn-rog-outline {
        background: transparent;
        border: 1px solid rgba(255,255,255,0.06);
        color: #fff;
        border-radius: 50px;
        padding: 14px 40px;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
        margin: 5px;
    }

    .btn-rog-outline:hover {
        border-color: #00CFFF;
        color: #fff;
        text-decoration: none;
    }

    .botones-group {
        display: flex;
        gap: 15px;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 10px;
    }

    @@media (max-width: 768px) {
        .confirm-rog-card {
            padding: 30px 20px;
        }
        .confirm-grid {
            grid-template-columns: 1fr;
        }
        .confirm-rog-card .detalles-envio .row {
            grid-template-columns: 1fr;
        }
        .confirm-rog-card h1 {
            font-size: 2rem;
        }
    }
</style>

<div class="confirm-rog-container">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="confirm-rog-card">
                    <div class="confirm-icon">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>

                    <h1>¡Pago Procesado!</h1>
                    <p class="subtitle">@Model.Mensaje</p>

                    <div class="pedido-info">
                        <div class="ref">
                            #@Model.NumeroPedido
                            <small>Referencia: @Model.NumeroReferencia</small>
                        </div>
                    </div>

                    <div class="confirm-grid">
                        <div class="item">
                            <div class="label">Total pagado</div>
                            <div class="value total">Bs @Model.Total</div>
                        </div>
                        <div class="item">
                            <div class="label">Fecha</div>
                            <div class="value">@Model.Fecha</div>
                        </div>
                    </div>

                    <div class="detalles-envio">
                        <div class="row">
                            <div>
                                <div class="label">📍 Dirección de envío</div>
                                <div class="value">@Model.DireccionEnvio</div>
                            </div>
                            <div>
                                <div class="label">💳 Método de pago</div>
                                <div class="value">@Model.MetodoPago</div>
                            </div>
                        </div>
                    </div>

                    <div style="background: rgba(0,207,255,0.05); border-radius: 12px; padding: 15px; margin-bottom: 30px;">
                        <small style="color: #fff;">
                            <i class="bi bi-envelope me-2" style="color: #00CFFF;"></i>
                            Te hemos enviado un correo con los detalles de tu compra.
                        </small>
                    </div>

                    <div class="botones-group">
                        <a asp-action="MisCompras" class="btn-rog-primary">
                            <i class="bi bi-box-seam me-2"></i>Ver mis compras
                        </a>
                        <a asp-action="Index" class="btn-rog-outline">
                            <i class="bi bi-house me-2"></i>Seguir comprando
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>