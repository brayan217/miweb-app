@model IEnumerable<LOGIN.Models.Producto>

@{
    ViewData["Title"] = "Tienda - Mi Inventario";
}

<style>
    .tienda-container {
        background: #0a0a0a;
        min-height: 100vh;
        padding: 40px 0;
        color: #fff;
        font-family: 'Inter', sans-serif;
    }

    .hero-simple {
        text-align: center;
        padding: 40px 0;
        border-bottom: 1px solid rgba(255,255,255,0.03);
        margin-bottom: 40px;
    }

        .hero-simple h1 {
            font-size: 3.5rem;
            font-weight: 800;
            letter-spacing: -2px;
        }

            .hero-simple h1 span {
                background: linear-gradient(135deg, #ff0044, #ff6b35);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

        .hero-simple p {
            color: rgba(255,255,255,0.25);
            font-size: 1.1rem;
            letter-spacing: 2px;
            font-weight: 300;
        }

    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 25px;
    }

    .product-item {
        background: rgba(18, 18, 30, 0.95);
        border: 1px solid rgba(255,255,255,0.04);
        border-radius: 16px;
        padding: 20px 20px 20px;
        transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        cursor: pointer;
        display: flex;
        flex-direction: column;
        box-shadow: 0 8px 30px rgba(0,0,0,0.6);
        position: relative;
        overflow: hidden;
    }

        .product-item::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, #ff0044, #ff6b35, transparent);
            opacity: 0;
            transition: opacity 0.4s ease;
        }

        .product-item:hover::before {
            opacity: 1;
        }

        .product-item:hover {
            background: rgba(25, 25, 45, 0.98);
            border-color: rgba(255,0,68,0.15);
            transform: translateY(-6px);
            box-shadow: 0 12px 50px rgba(0,0,0,0.8), 0 0 40px rgba(255,0,68,0.04);
        }

    .product-image-container {
        width: 100%;
        height: 180px;
        background: rgba(0,0,0,0.5);
        border-radius: 12px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
        position: relative;
        border: 1px solid rgba(255,255,255,0.03);
    }

    .product-image-fallback {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: rgba(255,255,255,0.06);
        height: 100%;
        width: 100%;
    }

        .product-image-fallback i {
            font-size: 3.5rem;
            color: rgba(255,0,68,0.12);
            margin-bottom: 8px;
        }

        .product-image-fallback span {
            font-size: 0.7rem;
            color: rgba(255,255,255,0.06);
            letter-spacing: 0.5px;
            font-weight: 300;
        }

    .stock-badge {
        position: absolute;
        top: 12px;
        right: 12px;
        padding: 4px 14px;
        border-radius: 50px;
        font-size: 0.55rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        background: rgba(6, 214, 160, 0.08);
        color: #06d6a0;
        border: 1px solid rgba(6, 214, 160, 0.06);
        z-index: 2;
        backdrop-filter: blur(10px);
    }

        .stock-badge.empty {
            background: rgba(239, 71, 111, 0.08);
            color: #ef476f;
            border-color: rgba(239, 71, 111, 0.06);
        }

    .product-name {
        font-size: 1rem;
        font-weight: 700;
        margin: 0 0 4px 0;
        color: #fff;
        letter-spacing: -0.2px;
    }

    .product-desc {
        font-size: 0.78rem;
        color: rgba(255,255,255,0.2);
        margin: 0 0 14px 0;
        flex: 1;
        letter-spacing: 0.2px;
        font-weight: 300;
    }

    .product-price {
        font-size: 1.4rem;
        font-weight: 800;
        color: #ff0044;
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        letter-spacing: -0.5px;
    }

        .product-price .old {
            font-size: 0.8rem;
            color: rgba(255,255,255,0.08);
            text-decoration: line-through;
            font-weight: 400;
            letter-spacing: 0px;
        }

    .stock-info {
        font-size: 0.65rem;
        color: rgba(255,255,255,0.08);
        margin-top: 6px;
        display: flex;
        align-items: center;
        gap: 6px;
        font-weight: 300;
        letter-spacing: 0.3px;
    }

        .stock-info .dot {
            display: inline-block;
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: #06d6a0;
            box-shadow: 0 0 10px rgba(6, 214, 160, 0.15);
        }

            .stock-info .dot.empty {
                background: #ef476f;
                box-shadow: 0 0 10px rgba(239, 71, 111, 0.15);
            }

    .btn-add {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255,255,255,0.06);
        color: rgba(255,255,255,0.7);
        border-radius: 50px;
        padding: 10px 20px;
        font-weight: 600;
        font-size: 0.8rem;
        transition: all 0.3s ease;
        width: 100%;
        margin-top: 16px;
        letter-spacing: 0.5px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        text-transform: uppercase;
    }

        .btn-add:hover {
            background: linear-gradient(135deg, #ff0044, #ff6b35);
            border-color: transparent;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 0 40px rgba(255,0,68,0.15);
        }

        .btn-add:disabled {
            opacity: 0.2;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
            background: rgba(255,255,255,0.02);
            border-color: rgba(255,255,255,0.02);
            color: rgba(255,255,255,0.1);
        }

            .btn-add:disabled:hover {
                background: rgba(255,255,255,0.02);
                box-shadow: none;
                transform: none;
            }

    .nav-simple {
        padding: 15px 0;
        border-bottom: 1px solid rgba(255,255,255,0.03);
        margin-bottom: 40px;
        background: rgba(0,0,0,0.2);
        border-radius: 12px;
    }

        .nav-simple a {
            color: rgba(255,255,255,0.15);
            text-decoration: none;
            margin: 0 20px;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 1.2px;
            transition: color 0.3s;
            cursor: pointer;
            text-transform: uppercase;
        }

            .nav-simple a:hover {
                color: rgba(255,255,255,0.6);
            }

            .nav-simple a.active {
                color: #ff0044 !important;
            }

    .section-title {
        font-weight: 700;
        color: #fff;
        margin: 0;
        letter-spacing: -0.5px;
        font-size: 1.2rem;
    }

        .section-title i {
            color: #ff0044;
            margin-right: 10px;
        }

    .section-count {
        color: rgba(255,255,255,0.04);
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    @@media (max-width: 768px) {
        .hero-simple h1 {
            font-size: 2.2rem;
        }

        .product-grid {
            grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
            gap: 16px;
        }

        .product-item {
            padding: 16px 14px 14px;
        }

        .product-image-container {
            height: 140px;
        }

        .product-price {
            font-size: 1.1rem;
        }

        .nav-simple a {
            margin: 0 10px;
            font-size: 0.55rem;
            letter-spacing: 0.8px;
        }

        .product-name {
            font-size: 0.85rem;
        }

        .btn-add {
            font-size: 0.7rem;
            padding: 8px 16px;
        }
    }
</style>

<div class="tienda-container">
    <div class="container">
        <div class="hero-simple">
            <h1>ROG <span>XREAL RX</span></h1>
            <p>Amplifica tu victoria</p>
        </div>

        <!-- ⭐ NAVEGACIÓN CORREGIDA: PRODUCTOS → Tienda pública -->
        <div class="nav-simple">
            <div class="container text-center">
                <a asp-controller="Home" asp-action="Index">REPÚBLICA DE GAMERS</a>
                <a asp-controller="Tienda" asp-action="Index" class="active">PRODUCTOS</a>
                <a asp-controller="Home" asp-action="Privacy">INNOVACIÓN</a>
                <a asp-controller="Home" asp-action="Privacy">SOPORTE</a>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="section-title">
                <i class="bi bi-grid-3x3-gap-fill"></i>Productos
            </h4>
            <span class="section-count">@Model.Count() productos</span>
        </div>

        <div class="product-grid">
            @foreach (var producto in Model)
            {
                <div class="product-item">
                    <div class="product-image-container">
                        <div class="product-image-fallback">
                            <i class="bi bi-box-seam"></i>
                            <span>@producto.Nombre</span>
                        </div>
                        @if (producto.Cantidad > 0)
                        {
                            <span class="stock-badge">● Disponible</span>
                        }
                        else
                        {
                            <span class="stock-badge empty">● Agotado</span>
                        }
                    </div>

                    <h5 class="product-name">@producto.Nombre</h5>
                    <p class="product-desc">@producto.Descripcion</p>
                    <div class="product-price">
                        Bs @producto.Precio.ToString("N0")
                        @if (producto.Precio > 10000)
                        {
                            <span class="old">Bs @((producto.Precio * 1.3m).ToString("N0"))</span>
                        }
                    </div>
                    <div class="stock-info">
                        @if (producto.Cantidad > 0)
                        {
                            <span class="dot"></span>
                            <span>@producto.Cantidad unidades</span>
                        }
                        else
                        {
                            <span class="dot empty"></span>
                            <span style="color: rgba(255,255,255,0.05);">Sin stock</span>
                        }
                    </div>
                    @if (producto.Cantidad > 0)
                    {
                        <button class="btn-add add-to-cart" data-id="@producto.Id">
                            <i class="bi bi-cart-plus"></i> Agregar
                        </button>
                    }
                    else
                    {
                        <button class="btn-add" disabled>
                            <i class="bi bi-x-circle"></i> Agotado
                        </button>
                    }
                </div>
            }
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function() {
        $('.add-to-cart').click(function() {
            var btn = $(this);
            var productoId = btn.data('id');
            var originalText = btn.html();

            btn.html('<i class="bi bi-hourglass-split"></i> Agregando...');
            btn.prop('disabled', true);

            $.post('/Tienda/AgregarAlCarrito', { productoId: productoId, cantidad: 1 })
                .done(function(response) {
                    if (response.success) {
                        alert(response.message);
                        location.reload();
                    } else {
                        alert(response.message);
                        btn.html(originalText);
                        btn.prop('disabled', false);
                    }
                })
                .fail(function() {
                    alert('Error al agregar al carrito');
                    btn.html(originalText);
                    btn.prop('disabled', false);
                });
        });
    });
</script>