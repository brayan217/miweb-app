@model IEnumerable<MiWeb.Models.Producto>

@{
    ViewData["Title"] = "NEO STORE - Tienda Gamer";
}

<style>
    .hero-full {
        min-height: 100vh;
        display: flex;
        align-items: center;
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, #090909 0%, #0a0a1a 50%, #090909 100%);
        padding: 80px 0;
    }

        .hero-full .hero-bg-glow {
            position: absolute;
            top: -30%;
            right: -10%;
            width: 700px;
            height: 700px;
            background: radial-gradient(circle, rgba(0,207,255,0.04) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .hero-full .hero-bg-glow-2 {
            position: absolute;
            bottom: -30%;
            left: -10%;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(122,0,255,0.04) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .hero-full .hero-title {
            font-family: 'Orbitron', sans-serif;
            font-weight: 900;
            font-size: 4.5rem;
            letter-spacing: -2px;
            color: #fff;
            line-height: 1.05;
        }

            .hero-full .hero-title .neon-text {
                background: linear-gradient(135deg, #00CFFF, #7A00FF);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                text-shadow: 0 0 60px rgba(0,207,255,0.15);
            }

        .hero-full .hero-subtitle {
            color: rgba(255,255,255,0.15);
            font-size: 1.2rem;
            letter-spacing: 4px;
            text-transform: uppercase;
            margin-top: 10px;
        }

    .hero-desc {
        color: rgba(255, 255, 255, 0.5);
        font-size: 1rem;
        max-width: 500px;
        margin-top: 15px;
    }

    .hero-full .hero-buttons {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        flex-wrap: wrap;
    }

    .btn-hero-primary {
        background: linear-gradient(135deg, #00CFFF, #7A00FF);
        color: #fff;
        border: none;
        border-radius: 50px;
        padding: 16px 45px;
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        transition: all 0.4s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 0 40px rgba(0,207,255,0.08);
    }

        .btn-hero-primary:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 0 60px rgba(0,207,255,0.15);
            color: #fff;
        }

    .btn-hero-secondary {
        background: transparent;
        border: 1px solid rgba(255,255,255,0.04);
        color: rgba(255,255,255,0.3);
        border-radius: 50px;
        padding: 16px 45px;
        font-weight: 600;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        transition: all 0.4s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-hero-secondary:hover {
            border-color: #00CFFF;
            color: #fff;
            box-shadow: 0 0 30px rgba(0,207,255,0.03);
        }

    /* ⭐ BOTÓN DE VOZ ⭐ */
    .btn-voice {
        background: transparent;
        border: 1px solid rgba(255,255,255,0.04);
        color: rgba(255,255,255,0.3);
        border-radius: 50px;
        padding: 16px 45px;
        font-weight: 600;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        transition: all 0.4s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-voice:hover {
            border-color: #00CFFF;
            color: #fff;
            box-shadow: 0 0 30px rgba(0,207,255,0.03);
        }

        .btn-voice.active {
            border-color: #ffc107;
            color: #ffc107;
            animation: pulse-voice 1.5s ease-in-out infinite;
        }

    @@keyframes pulse-voice {
        0%, 100% {
            box-shadow: 0 0 20px rgba(255,193,7,0.05);
        }

        50% {
            box-shadow: 0 0 40px rgba(255,193,7,0.15);
        }
    }

    .hero-full .hero-image {
        max-width: 100%;
        filter: drop-shadow(0 0 80px rgba(0,207,255,0.04));
    }

    /* ⭐ MODAL DE VOZ ⭐ */
    .voice-modal {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(10, 10, 10, 0.92);
        backdrop-filter: blur(15px);
        z-index: 9999;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

        .voice-modal.active {
            display: flex;
        }

    .voice-modal-content {
        width: 100%;
        max-width: 600px;
        background: rgba(18, 18, 30, 0.8);
        border: 1px solid rgba(255,193,7,0.15);
        border-radius: 28px;
        padding: 40px;
        box-shadow: 0 30px 80px rgba(0,0,0,0.6);
    }

        .voice-modal-content .voice-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

            .voice-modal-content .voice-header h2 {
                color: #ffc107;
                font-size: 1.5rem;
                font-weight: 900;
                margin: 0;
            }

            .voice-modal-content .voice-header .btn-close-voice {
                background: rgba(255,255,255,0.03);
                border: 1px solid rgba(255,255,255,0.03);
                color: rgba(255,255,255,0.3);
                border-radius: 50%;
                width: 40px;
                height: 40px;
                font-size: 1.2rem;
                cursor: pointer;
                transition: all 0.3s ease;
                display: flex;
                align-items: center;
                justify-content: center;
            }

                .voice-modal-content .voice-header .btn-close-voice:hover {
                    border-color: #ff4757;
                    color: #ff4757;
                }

    .voice-status {
        background: rgba(255,193,7,0.05);
        border: 1px solid rgba(255,193,7,0.1);
        border-radius: 16px;
        padding: 12px 18px;
        color: rgba(255,255,255,0.5);
        font-size: 0.85rem;
        margin-bottom: 20px;
    }

        .voice-status.ok {
            background: rgba(0,207,255,0.05);
            border-color: rgba(0,207,255,0.1);
            color: #00CFFF;
        }

        .voice-status.error {
            background: rgba(255,71,87,0.05);
            border-color: rgba(255,71,87,0.1);
            color: #ff4757;
        }

    .voice-textarea {
        width: 100%;
        min-height: 200px;
        resize: vertical;
        background: rgba(0,0,0,0.3);
        color: #fff;
        border: 1px solid rgba(255,255,255,0.03);
        border-radius: 16px;
        padding: 18px;
        outline: none;
        font-size: 16px;
        line-height: 1.6;
        font-family: inherit;
    }

        .voice-textarea:focus {
            border-color: rgba(255,193,7,0.2);
            box-shadow: 0 0 0 3px rgba(255,193,7,0.05);
        }

    .voice-preview {
        min-height: 28px;
        color: rgba(255,255,255,0.2);
        margin-top: 12px;
        font-style: italic;
        font-size: 0.85rem;
    }

    .voice-buttons {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 20px;
    }

        .voice-buttons button {
            border: none;
            border-radius: 50px;
            padding: 12px 24px;
            font-weight: 700;
            font-size: 0.8rem;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

            .voice-buttons button:hover {
                transform: translateY(-2px);
            }

    .btn-voice-start {
        background: linear-gradient(135deg, #ffc107, #ffb300);
        color: #111;
    }

        .btn-voice-start:disabled {
            opacity: 0.3;
            cursor: not-allowed;
            transform: none !important;
        }

        .btn-voice-start.active {
            animation: pulse-voice-btn 1s ease-in-out infinite;
        }

    @@keyframes pulse-voice-btn {
        0%, 100% {
            box-shadow: 0 0 20px rgba(255,193,7,0.1);
        }

        50% {
            box-shadow: 0 0 40px rgba(255,193,7,0.3);
        }
    }

    .btn-voice-stop {
        background: linear-gradient(135deg, #ff4757, #c0392b);
        color: #fff;
    }

    .btn-voice-clear {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.03);
        color: rgba(255,255,255,0.3);
    }

        .btn-voice-clear:hover {
            border-color: rgba(255,255,255,0.06);
            color: #fff;
        }

    .btn-voice-copy {
        background: rgba(0,207,255,0.05);
        border: 1px solid rgba(0,207,255,0.05);
        color: #00CFFF;
    }

        .btn-voice-copy:hover {
            border-color: #00CFFF;
            background: rgba(0,207,255,0.08);
        }

    .voice-close {
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.03);
        color: rgba(255,255,255,0.2);
        flex: 1;
    }

        .voice-close:hover {
            border-color: rgba(255,255,255,0.06);
            color: #fff;
        }

    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 30px;
    }

    .product-item {
        background: rgba(18, 18, 30, 0.4);
        border: 1px solid rgba(255,255,255,0.02);
        border-radius: 20px;
        padding: 20px 20px 25px;
        transition: all 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        cursor: default;
        display: flex;
        flex-direction: column;
        position: relative;
        overflow: hidden;
        transform-style: preserve-3d;
        backdrop-filter: blur(10px);
    }

        .product-item::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle at center, rgba(0,207,255,0.02) 0%, transparent 60%);
            opacity: 0;
            transition: opacity 0.6s ease;
            pointer-events: none;
        }

        .product-item:hover::before {
            opacity: 1;
        }

        .product-item .product-image-container {
            width: 100%;
            height: 200px;
            background: rgba(0,0,0,0.3);
            border-radius: 16px;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 16px;
            position: relative;
            border: 1px solid rgba(255,255,255,0.02);
        }

        .product-item .product-image-fallback {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: rgba(255,255,255,0.04);
            height: 100%;
            width: 100%;
        }

            .product-item .product-image-fallback i {
                font-size: 3.5rem;
                color: rgba(255,0,68,0.08);
                margin-bottom: 8px;
            }

            .product-item .product-image-fallback span {
                font-size: 0.7rem;
                color: rgba(255,255,255,0.04);
                letter-spacing: 0.5px;
            }

    .stock-badge {
        position: absolute;
        top: 12px;
        right: 12px;
        padding: 4px 14px;
        border-radius: 50px;
        font-size: 0.5rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        background: rgba(6, 214, 160, 0.08);
        color: #06d6a0;
        border: 1px solid rgba(6, 214, 160, 0.06);
        z-index: 2;
        backdrop-filter: blur(10px);
    }

        .stock-badge.empty {
            background: rgba(239, 71, 111, 0.08);
            color: #ef476f;
            border-color: rgba(239, 71, 111, 0.06);
        }

    .product-name {
        font-size: 1rem;
        font-weight: 700;
        margin: 0 0 4px 0;
        color: #fff;
        letter-spacing: -0.2px;
    }

    .product-desc {
        font-size: 0.78rem;
        color: rgba(255, 255, 255, 0.5);
        margin: 0 0 14px 0;
        flex: 1;
        font-weight: 300;
    }

    .product-price {
        font-size: 1.4rem;
        font-weight: 800;
        color: #00CFFF;
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        letter-spacing: -0.5px;
    }

        .product-price .old {
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.3);
            text-decoration: line-through;
            font-weight: 400;
        }

    .stock-info {
        font-size: 0.6rem;
        color: rgba(255, 255, 255, 0.3);
        margin-top: 6px;
        display: flex;
        align-items: center;
        gap: 6px;
        font-weight: 300;
    }

        .stock-info .dot {
            display: inline-block;
            width: 4px;
            height: 4px;
            border-radius: 50%;
            background: #06d6a0;
        }

            .stock-info .dot.empty {
                background: #ef476f;
            }

    .btn-add {
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.03);
        color: rgba(255,255,255,0.3);
        border-radius: 50px;
        padding: 10px 20px;
        font-weight: 600;
        font-size: 0.75rem;
        transition: all 0.3s ease;
        width: 100%;
        margin-top: 16px;
        letter-spacing: 0.8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        text-transform: uppercase;
        position: relative;
        overflow: hidden;
    }

        .btn-add:hover {
            background: linear-gradient(135deg, #ff0044, #ff6b35);
            border-color: transparent;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 0 30px rgba(255,0,68,0.05);
        }

        .btn-add:disabled {
            opacity: 0.1;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

    .categories-section {
        padding: 60px 0;
    }

    .categories-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 15px;
    }

    .category-item {
        background: rgba(255,255,255,0.01);
        border: 1px solid rgba(255,255,255,0.02);
        border-radius: 16px;
        padding: 20px 15px;
        text-align: center;
        transition: all 0.4s ease;
        cursor: pointer;
        text-decoration: none;
        color: rgba(255, 255, 255, 0.4);
    }

        .category-item:hover {
            background: rgba(255,255,255,0.02);
            border-color: rgba(0,207,255,0.05);
            transform: translateY(-5px);
            color: #fff;
        }

        .category-item i {
            font-size: 2rem;
            display: block;
            margin-bottom: 8px;
            color: #00CFFF;
            opacity: 0.2;
            transition: all 0.4s ease;
        }

        .category-item:hover i {
            opacity: 1;
            text-shadow: 0 0 30px rgba(0,207,255,0.1);
        }

        .category-item span {
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

    .section-count {
        color: rgba(255, 255, 255, 0.2);
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 1px;
    }

    @@media (max-width: 768px) {
        .hero-full .hero-title {
            font-size: 2.8rem;
        }

        .hero-full .hero-buttons {
            flex-direction: column;
            align-items: stretch;
        }

        .product-grid {
            grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
            gap: 16px;
        }

        .categories-grid {
            grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        }

        .voice-modal-content {
            padding: 25px;
        }
    }

    @@media (max-width: 480px) {
        .hero-full .hero-title {
            font-size: 2rem;
        }

        .product-grid {
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }

        .product-item .product-image-container {
            height: 120px;
        }

        .product-item .product-name {
            font-size: 0.8rem;
        }

        .product-item .product-price {
            font-size: 0.9rem;
        }

        .product-item .btn-add {
            font-size: 0.6rem;
            padding: 6px 10px;
        }

        .voice-buttons {
            flex-direction: column;
        }

            .voice-buttons button {
                width: 100%;
                justify-content: center;
            }
    }
</style>

<div class="hero-full">
    <div class="hero-bg-glow"></div>
    <div class="hero-bg-glow-2"></div>
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7" data-aos="fade-right" data-aos-duration="1000">
                <span class="hero-subtitle">⚡ Bienvenido al futuro</span>
                <h1 class="hero-title">
                    <span class="neon-text">NEO STORE</span><br />
                    <span style="color: rgba(255,255,255,0.8);">La tienda gamer</span>
                </h1>
                <p class="hero-desc">Explora lo último en tecnología gaming, donde el rendimiento se encuentra con el estilo futurista.</p>
                <div class="hero-buttons">
                    <a href="#productos" class="btn-hero-primary">
                        <i class="bi bi-rocket-takeoff"></i> Explorar
                    </a>
                    <a asp-controller="Tienda" asp-action="Index" class="btn-hero-secondary">
                        <i class="bi bi-grid-3x3-gap-fill"></i> Ver todos
                    </a>
                    <!-- ⭐ BOTÓN DE VOZ ⭐ -->
                    <button id="openVoiceModalBtn" class="btn-voice">
                        <i class="bi bi-mic"></i> Voz
                    </button>
                </div>
            </div>
            <div class="col-lg-5 text-center" data-aos="fade-left" data-aos-duration="1000" data-aos-delay="200">
                <img src="https://via.placeholder.com/500x500/0a0a1a/00CFFF?text=NEO+STORE" alt="NEO STORE" class="hero-image" />
            </div>
        </div>
    </div>
</div>

<div class="container categories-section" data-aos="fade-up">
    <h2 class="section-title" style="text-align: center; margin-bottom: 30px;">
        <i class="bi bi-grid-3x3-gap-fill" style="color: #00CFFF;"></i>
        <span style="font-weight: 700; letter-spacing: -1px; color: #fff;">Categorías</span>
    </h2>
    <div class="categories-grid">
        <a asp-controller="Tienda" asp-action="Index" asp-route-searchString="Laptop" class="category-item" data-aos="zoom-in" data-aos-delay="0">
            <i class="bi bi-laptop"></i>
            <span>Laptops</span>
        </a>
        <a asp-controller="Tienda" asp-action="Index" asp-route-searchString="PC" class="category-item" data-aos="zoom-in" data-aos-delay="50">
            <i class="bi bi-pc-display"></i>
            <span>PC Gamer</span>
        </a>
        <a asp-controller="Tienda" asp-action="Index" asp-route-searchString="Monitor" class="category-item" data-aos="zoom-in" data-aos-delay="100">
            <i class="bi bi-tv"></i>
            <span>Monitores</span>
        </a>
        <a asp-controller="Tienda" asp-action="Index" asp-route-searchString="Componente" class="category-item" data-aos="zoom-in" data-aos-delay="150">
            <i class="bi bi-cpu"></i>
            <span>Componentes</span>
        </a>
        <a asp-controller="Tienda" asp-action="Index" asp-route-searchString="Accesorio" class="category-item" data-aos="zoom-in" data-aos-delay="200">
            <i class="bi bi-keyboard"></i>
            <span>Accesorios</span>
        </a>
        <a asp-controller="Tienda" asp-action="Index" asp-route-searchString="Streaming" class="category-item" data-aos="zoom-in" data-aos-delay="250">
            <i class="bi bi-mic"></i>
            <span>Streaming</span>
        </a>
        <a asp-controller="Tienda" asp-action="Index" asp-route-searchString="Consola" class="category-item" data-aos="zoom-in" data-aos-delay="300">
            <i class="bi bi-controller"></i>
            <span>Consolas</span>
        </a>
        <a asp-controller="Tienda" asp-action="Index" asp-route-searchString="Silla" class="category-item" data-aos="zoom-in" data-aos-delay="350">
            <i class="bi bi-chair"></i>
            <span>Sillas Gamer</span>
        </a>
    </div>
</div>

<div class="container" id="productos" style="padding-bottom: 60px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="section-title" style="font-weight: 700; letter-spacing: -1px; color: #fff;">
            <i class="bi bi-grid-3x3-gap-fill" style="color: #00CFFF;"></i>
            <span>Productos</span>
        </h4>
        <span class="section-count">@Model.Count() productos</span>
    </div>

    <div class="product-grid">
        @foreach (var producto in Model)
        {
            <div class="product-item">
                <div class="product-image-container">
                    <div class="product-image-fallback">
                        <i class="bi bi-box-seam"></i>
                        <span>@producto.Nombre</span>
                    </div>
                    @if (producto.Cantidad > 0)
                    {
                        <span class="stock-badge">● Disponible</span>
                    }
                    else
                    {
                        <span class="stock-badge empty">● Agotado</span>
                    }
                </div>

                <h5 class="product-name">@producto.Nombre</h5>
                <p class="product-desc">@producto.Descripcion</p>
                <div class="product-price">
                    Bs @producto.Precio.ToString("N0")
                    @if (producto.Precio > 10000)
                    {
                        <span class="old">Bs @((producto.Precio * 1.3m).ToString("N0"))</span>
                    }
                </div>
                <div class="stock-info">
                    @if (producto.Cantidad > 0)
                    {
                        <span class="dot"></span>
                        <span>@producto.Cantidad unidades</span>
                    }
                    else
                    {
                        <span class="dot empty"></span>
                        <span style="color: rgba(255,255,255,0.03);">Sin stock</span>
                    }
                </div>
                @if (producto.Cantidad > 0)
                {
                    <button class="btn-add add-to-cart" data-id="@producto.Id">
                        <i class="bi bi-cart-plus"></i> Agregar
                    </button>
                }
                else
                {
                    <button class="btn-add" disabled>
                        <i class="bi bi-x-circle"></i> Agotado
                    </button>
                }
            </div>
        }
    </div>
</div>

<!-- ⭐ MODAL DE RECONOCIMIENTO DE VOZ ⭐ -->
<div id="voiceModal" class="voice-modal">
    <div class="voice-modal-content">
        <div class="voice-header">
            <h2>🎤 Buscar por voz</h2>
            <button id="closeVoiceModalBtn" class="btn-close-voice">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <p style="color: rgba(255,255,255,0.3); font-size: 0.85rem; margin-bottom: 15px;">
            Habla para buscar productos en NEO STORE.
        </p>

        <div id="voiceStatus" class="voice-status">
            Estado: esperando iniciar el micrófono.
        </div>

        <textarea id="voiceText" class="voice-textarea" placeholder="Aquí aparecerá el texto reconocido por voz..."></textarea>

        <div id="voicePreview" class="voice-preview"></div>

        <div class="voice-buttons">
            <button id="voiceStartBtn" class="btn-voice-start">🎙️ Iniciar voz</button>
            <button id="voiceStopBtn" class="btn-voice-stop">⏹️ Detener</button>
            <button id="voiceClearBtn" class="btn-voice-clear">🧹 Limpiar</button>
            <button id="voiceCopyBtn" class="btn-voice-copy">📋 Copiar</button>
            <button id="voiceSearchBtn" class="btn-voice-start" style="background: linear-gradient(135deg, #00CFFF, #7A00FF); color: #fff; flex: 1;">
                <i class="bi bi-search"></i> Buscar
            </button>
        </div>

        <div style="margin-top: 15px;">
            <button id="voiceCloseBtn" class="btn-voice-clear" style="width: 100%; padding: 12px;">
                <i class="bi bi-x-circle"></i> Cerrar
            </button>
        </div>

        <div style="margin-top: 12px; font-size: 0.7rem; color: rgba(255,255,255,0.05); text-align: center;">
            Recomendado para Google Chrome o Microsoft Edge
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function() {
        // ============================================
        // AGREGAR AL CARRITO
        // ============================================
        $('.add-to-cart').click(function() {
            var btn = $(this);
            var productoId = btn.data('id');
            var originalText = btn.html();

            btn.html('<i class="bi bi-hourglass-split"></i> Agregando...');
            btn.prop('disabled', true);

            $.post('/Tienda/AgregarAlCarrito', { productoId: productoId, cantidad: 1 })
                .done(function(response) {
                    if (response.success) {
                        alert(response.message);
                        location.reload();
                    } else {
                        alert(response.message);
                        btn.html(originalText);
                        btn.prop('disabled', false);
                    }
                })
                .fail(function() {
                    alert('Error al agregar al carrito');
                    btn.html(originalText);
                    btn.prop('disabled', false);
                });
        });

        // ============================================
        // RECONOCIMIENTO DE VOZ
        // ============================================
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

        const voiceModal = document.getElementById('voiceModal');
        const openVoiceBtn = document.getElementById('openVoiceModalBtn');
        const closeVoiceBtn = document.getElementById('closeVoiceModalBtn');
        const voiceCloseBtn = document.getElementById('voiceCloseBtn');

        const voiceStatus = document.getElementById('voiceStatus');
        const voiceText = document.getElementById('voiceText');
        const voicePreview = document.getElementById('voicePreview');

        const voiceStartBtn = document.getElementById('voiceStartBtn');
        const voiceStopBtn = document.getElementById('voiceStopBtn');
        const voiceClearBtn = document.getElementById('voiceClearBtn');
        const voiceCopyBtn = document.getElementById('voiceCopyBtn');
        const voiceSearchBtn = document.getElementById('voiceSearchBtn');

        let recognition = null;
        let escuchando = false;

        // Abrir modal
        openVoiceBtn.addEventListener('click', function() {
            voiceModal.classList.add('active');
            document.body.style.overflow = 'hidden';
        });

        // Cerrar modal
        function closeVoiceModal() {
            voiceModal.classList.remove('active');
            document.body.style.overflow = '';
            if (escuchando) {
                detenerVoz();
            }
        }

        closeVoiceBtn.addEventListener('click', closeVoiceModal);
        voiceCloseBtn.addEventListener('click', closeVoiceModal);

        // Cerrar con ESC
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeVoiceModal();
            }
        });

        // Cerrar click fuera
        voiceModal.addEventListener('click', function(e) {
            if (e.target === voiceModal) {
                closeVoiceModal();
            }
        });

        function cambiarEstado(mensaje, tipo) {
            voiceStatus.innerText = mensaje;
            voiceStatus.classList.remove('ok', 'error');

            if (tipo === 'ok') {
                voiceStatus.classList.add('ok');
            }
            if (tipo === 'error') {
                voiceStatus.classList.add('error');
            }
        }

        function iniciarVoz() {
            if (!SpeechRecognition) {
                cambiarEstado('Tu navegador no soporta Web Speech API. Prueba en Chrome o Edge.', 'error');
                voiceStartBtn.disabled = true;
                return;
            }

            if (escuchando) {
                cambiarEstado('El micrófono ya está escuchando.', 'ok');
                return;
            }

            if (!recognition) {
                recognition = new SpeechRecognition();
                recognition.lang = 'es-ES';
                recognition.continuous = true;
                recognition.interimResults = true;
                recognition.maxAlternatives = 1;

                recognition.onstart = function() {
                    escuchando = true;
                    voiceStartBtn.classList.add('active');
                    voiceStartBtn.textContent = '🎙️ Escuchando...';
                    cambiarEstado('🎤 Escuchando... habla claramente al micrófono.', 'ok');
                };

                recognition.onresult = function(event) {
                    let textoFinal = '';
                    let textoTemporal = '';

                    for (let i = event.resultIndex; i < event.results.length; i++) {
                        const texto = event.results[i][0].transcript;

                        if (event.results[i].isFinal) {
                            textoFinal += texto + ' ';
                        } else {
                            textoTemporal += texto;
                        }
                    }

                    if (textoFinal.trim() !== '') {
                        const textoActual = voiceText.value.trim();

                        if (textoActual === '') {
                            voiceText.value = textoFinal.trim();
                        } else {
                            voiceText.value = textoActual + ' ' + textoFinal.trim();
                        }

                        voiceText.scrollTop = voiceText.scrollHeight;
                        voicePreview.innerText = '';
                    } else {
                        voicePreview.innerText = 'Escuchando: ' + textoTemporal;
                    }
                };

                recognition.onerror = function(event) {
                    voiceStartBtn.classList.remove('active');
                    voiceStartBtn.textContent = '🎙️ Iniciar voz';

                    if (event.error === 'not-allowed') {
                        cambiarEstado('Permiso de micrófono denegado. Activa el permiso del navegador.', 'error');
                    } else if (event.error === 'no-speech') {
                        cambiarEstado('No se detectó voz. Intenta hablar más cerca del micrófono.', 'error');
                    } else {
                        cambiarEstado('Error de reconocimiento: ' + event.error, 'error');
                    }
                };

                recognition.onend = function() {
                    voiceStartBtn.classList.remove('active');
                    voiceStartBtn.textContent = '🎙️ Iniciar voz';

                    if (escuchando) {
                        try {
                            recognition.start();
                        } catch (error) {
                            cambiarEstado('El micrófono se detuvo. Presiona iniciar otra vez.', 'error');
                            escuchando = false;
                        }
                    } else {
                        cambiarEstado('Estado: micrófono detenido.');
                    }
                };
            }

            try {
                escuchando = true;
                recognition.start();
            } catch (error) {
                cambiarEstado('No se pudo iniciar el micrófono. Intenta nuevamente.', 'error');
            }
        }

        function detenerVoz() {
            escuchando = false;
            voicePreview.innerText = '';
            voiceStartBtn.classList.remove('active');
            voiceStartBtn.textContent = '🎙️ Iniciar voz';

            if (recognition) {
                try {
                    recognition.stop();
                } catch (e) {}
            }

            cambiarEstado('Estado: micrófono detenido.');
        }

        voiceStartBtn.addEventListener('click', iniciarVoz);

        voiceStopBtn.addEventListener('click', function() {
            detenerVoz();
        });

        voiceClearBtn.addEventListener('click', function() {
            voiceText.value = '';
            voicePreview.innerText = '';
            cambiarEstado('Texto limpiado. Puedes iniciar una nueva prueba.', 'ok');
        });

        voiceCopyBtn.addEventListener('click', async function() {
            const texto = voiceText.value.trim();

            if (texto === '') {
                cambiarEstado('No hay texto para copiar.', 'error');
                return;
            }

            try {
                await navigator.clipboard.writeText(texto);
                cambiarEstado('Texto copiado al portapapeles.', 'ok');
            } catch (error) {
                voiceText.select();
                document.execCommand('copy');
                cambiarEstado('Texto copiado.', 'ok');
            }
        });

        voiceSearchBtn.addEventListener('click', function() {
            const texto = voiceText.value.trim();

            if (texto === '') {
                cambiarEstado('No hay texto para buscar.', 'error');
                return;
            }

            // Redirigir a la tienda con el texto de búsqueda
            window.location.href = '/Tienda/Index?searchString=' + encodeURIComponent(texto);
        });

        // ============================================
        // VOZ POR TECLADO - ENTER
        // ============================================
        voiceText.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                voiceSearchBtn.click();
            }
        });

        // ============================================
        // VOZ POR TECLADO - Ctrl+Enter
        // ============================================
        voiceText.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' && e.ctrlKey) {
                e.preventDefault();
                voiceSearchBtn.click();
            }
        });
    });
</script>