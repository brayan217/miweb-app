@model IEnumerable<LOGIN.Models.Pedido>

@{
    ViewData["Title"] = "Mis Compras";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 fw-bold">
            <i class="bi bi-box-seam"></i> Mis Compras
        </h1>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Seguir comprando
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        @foreach (var pedido in Model)
        {
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start flex-wrap">
                        <div>
                            <div class="fw-bold">#@pedido.NumeroReferencia</div>
                            <small class="text-muted">
                                <i class="bi bi-calendar3"></i> @pedido.FechaPedido.ToString("dd/MM/yyyy HH:mm")
                            </small>
                        </div>
                        <div>
                            @{ 
                                var estadoTexto = pedido.Estado.ToString();
                                var badgeClass = estadoTexto == "Confirmado" ? "bg-success" :
                                                 estadoTexto == "Pendiente" ? "bg-warning" :
                                                 estadoTexto == "Enviado" ? "bg-info" :
                                                 estadoTexto == "Cancelado" ? "bg-danger" : "bg-secondary";
                            }
                            <span class="badge @badgeClass">
                                @estadoTexto
                            </span>
                            <span class="fw-bold text-primary ms-3">
                                Total: @pedido.Total.ToString("C")
                            </span>
                        </div>
                    </div>

                    @if (pedido.Detalles != null && pedido.Detalles.Any())
                    {
                        <hr />
                        <div class="row g-2">
                            @foreach (var detalle in pedido.Detalles)
                            {
                                <div class="col-md-4 col-lg-3">
                                    <div class="border rounded p-2">
                                        <div class="fw-bold small">@detalle.Producto?.Nombre</div>
                                        <div class="text-muted small">
                                            @detalle.Cantidad x @detalle.PrecioUnitario.ToString("C")
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox" style="font-size: 4rem; color: #dee2e6;"></i>
            <h3 class="mt-3">No tienes compras realizadas</h3>
            <p class="text-muted">¡Explora nuestra tienda y haz tu primera compra!</p>
            <a asp-action="Index" class="btn btn-gradient">
                <i class="bi bi-shop"></i> Ir a la tienda
            </a>
        </div>
    }
</div>

<style>
    .btn-gradient {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        border-radius: 2rem;
        padding: 0.75rem 2rem;
        transition: all 0.3s;
    }
    .btn-gradient:hover {
        transform: scale(1.05);
        color: white;
    }
    .card {
        border-radius: 1rem;
        overflow: hidden;
        transition: all 0.3s;
    }
    .card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.1) !important;
    }
    .badge {
        font-size: 0.8rem;
        padding: 0.5rem 1rem;
    }
</style>