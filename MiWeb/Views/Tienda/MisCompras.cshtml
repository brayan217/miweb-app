@model List<MiWeb.Models.Pedido>
@{
    ViewData["Title"] = "Mis Compras - NEO STORE";
    Layout = "~/Views/Shared/LayoutTienda.cshtml";
}

<style>
    .miscompras-rog-container {
        background: #0a0a0a;
        min-height: 100vh;
        padding: 40px 0;
        color: #FFFFFF;
        font-family: 'Inter', sans-serif;
    }

    .miscompras-rog-container h2 {
        font-size: 2rem;
        font-weight: 900;
        color: #FFFFFF;
    }

    .miscompras-rog-container h2 span {
        background: linear-gradient(135deg, #00CFFF, #7A00FF);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .pedido-card {
        background: rgba(18, 18, 30, 0.6);
        border: 1px solid rgba(255,255,255,0.03);
        border-radius: 16px;
        padding: 25px;
        margin-bottom: 20px;
        backdrop-filter: blur(10px);
        transition: all 0.3s ease;
    }

    .pedido-card:hover {
        border-color: rgba(0,207,255,0.1);
        transform: translateY(-2px);
    }

    .pedido-card .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        margin-bottom: 15px;
        padding-bottom: 15px;
        border-bottom: 1px solid rgba(255,255,255,0.03);
    }

    .pedido-card .header .numero {
        font-weight: 700;
        color: #00CFFF;
    }

    .pedido-card .header .fecha {
        color: rgba(255,255,255,0.3);
        font-size: 0.85rem;
    }

    .badge-estado {
        display: inline-block;
        padding: 4px 14px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .badge-estado.confirmado { background: rgba(0,207,255,0.1); color: #00CFFF; }
    .badge-estado.pendiente { background: rgba(255,165,0,0.1); color: #ffa502; }
    .badge-estado.enviado { background: rgba(46,213,115,0.1); color: #2ed573; }
    .badge-estado.entregado { background: rgba(0,207,255,0.05); color: rgba(255,255,255,0.3); }
    .badge-estado.cancelado { background: rgba(255,71,87,0.1); color: #ff4757; }

    .pedido-card .detalles {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 15px;
        margin-top: 15px;
    }

    .pedido-card .detalles .item {
        background: rgba(255,255,255,0.02);
        border-radius: 8px;
        padding: 12px;
        border: 1px solid rgba(255,255,255,0.02);
    }

    .pedido-card .detalles .item .label {
        color: rgba(255,255,255,0.15);
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .pedido-card .detalles .item .value {
        font-weight: 600;
        margin-top: 4px;
    }

    .pedido-card .detalles .item .value.total {
        color: #00CFFF;
        font-size: 1.2rem;
    }

    .pedido-card .productos {
        margin-top: 15px;
        padding-top: 15px;
        border-top: 1px solid rgba(255,255,255,0.03);
    }

    .pedido-card .productos .producto-item {
        display: flex;
        justify-content: space-between;
        padding: 5px 0;
        font-size: 0.9rem;
        color: rgba(255,255,255,0.5);
    }

    .pedido-card .productos .producto-item .nombre {
        color: rgba(255,255,255,0.7);
    }

    .pedido-card .productos .ver-mas {
        color: rgba(255,255,255,0.15);
        font-size: 0.8rem;
        margin-top: 5px;
    }

    .btn-rog-primary {
        background: linear-gradient(135deg, #00CFFF, #7A00FF);
        color: #FFFFFF;
        border: none;
        border-radius: 50px;
        padding: 8px 20px;
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

    .btn-rog-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 0 30px rgba(0,207,255,0.2);
        color: #FFFFFF;
        text-decoration: none;
    }

    .btn-rog-outline {
        background: transparent;
        border: 1px solid rgba(255,255,255,0.06);
        color: rgba(255,255,255,0.3);
        border-radius: 50px;
        padding: 8px 20px;
        font-weight: 600;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

    .btn-rog-outline:hover {
        border-color: #00CFFF;
        color: #FFFFFF;
        text-decoration: none;
    }

    .empty-state {
        text-align: center;
        padding: 60px 0;
    }

    .empty-state i {
        font-size: 4rem;
        color: rgba(255,255,255,0.03);
        margin-bottom: 20px;
    }

    .empty-state h4 {
        color: rgba(255,255,255,0.3);
        margin-bottom: 10px;
    }

    .empty-state p {
        color: rgba(255,255,255,0.1);
    }

    .acciones-recibo {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 10px;
    }

    @@media (max-width: 768px) {
        .pedido-card .detalles {
            grid-template-columns: 1fr;
        }
        .acciones-recibo {
            flex-direction: column;
        }
        .acciones-recibo a {
            text-align: center;
        }
    }
</style>

<div class="miscompras-rog-container">
    <div class="container">
        <h2 class="mb-4">Mis <span>Compras</span></h2>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="bi bi-box-seam"></i>
                <h4>No tienes compras realizadas</h4>
                <p>¡Explora nuestra tienda y encuentra los mejores productos gamer!</p>
                <a asp-action="Index" class="btn-rog-primary mt-3">
                    <i class="bi bi-shop me-2"></i>Ir a la tienda
                </a>
            </div>
        }
        else
        {
            @foreach (var pedido in Model)
            {
                <div class="pedido-card">
                    <div class="header">
                        <div>
                            <span class="numero">#@pedido.Id</span>
                            <span class="badge-estado @pedido.Estado.ToString().ToLower()">
                                @pedido.Estado
                            </span>
                            <span style="color: rgba(255,255,255,0.1); font-size: 0.7rem; margin-left: 10px;">
                                Ref: @pedido.NumeroReferencia
                            </span>
                        </div>
                        <span class="fecha">@pedido.FechaPedido.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>

                    <div class="detalles">
                        <div class="item">
                            <div class="label">Total</div>
                            <div class="value total">Bs @pedido.Total.ToString("N0")</div>
                        </div>
                        <div class="item">
                            <div class="label">Método de pago</div>
                            <div class="value">@pedido.MetodoPago</div>
                        </div>
                        <div class="item">
                            <div class="label">Envío</div>
                            <div class="value" style="font-size:0.8rem; color: rgba(255,255,255,0.3);">
                                @pedido.DireccionEnvio
                            </div>
                        </div>
                    </div>

                    @if (pedido.Detalles != null && pedido.Detalles.Any())
                    {
                        <div class="productos">
                            @foreach (var detalle in pedido.Detalles.Take(3))
                            {
                                <div class="producto-item">
                                    <span class="nombre">@detalle.Producto?.Nombre</span>
                                    <span>× @detalle.Cantidad</span>
                                </div>
                            }
                            @if (pedido.Detalles.Count > 3)
                            {
                                <div class="ver-mas">... y @(pedido.Detalles.Count - 3) más</div>
                            }
                        </div>
                    }

                    <!-- ⭐ BOTONES DE ACCIÓN CON RECIBO ⭐ -->
                    <div class="acciones-recibo">
                        <a asp-action="Recibo" asp-route-id="@pedido.Id" class="btn-rog-primary">
                            <i class="bi bi-file-text me-1"></i> Ver Recibo
                        </a>
                        <span style="color: rgba(255,255,255,0.1); font-size: 0.7rem; display: flex; align-items: center;">
                            <i class="bi bi-printer me-1"></i> Imprime o guarda como PDF
                        </span>
                    </div>
                </div>
            }
        }
    </div>
</div>