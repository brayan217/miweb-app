@{
    ViewData["Title"] = "Mis Compras - NEO STORE";
    var pedidos = ViewBag.Pedidos as List<Pedido> ?? new List<Pedido>();
}

<style>
    .compras-rog-container {
        background: #0a0a0a;
        min-height: 100vh;
        padding: 40px 0;
        color: #fff;
        font-family: 'Inter', sans-serif;
    }

    .compras-rog-container h1 {
        font-size: 2.5rem;
        font-weight: 900;
        letter-spacing: -1px;
    }

    .compras-rog-container h1 span {
        background: linear-gradient(135deg, #00CFFF, #7A00FF);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .pedido-rog-card {
        background: rgba(18, 18, 30, 0.6);
        border: 1px solid rgba(255,255,255,0.03);
        border-radius: 16px;
        padding: 25px;
        margin-bottom: 20px;
        transition: all 0.3s ease;
    }

    .pedido-rog-card:hover {
        background: rgba(25, 25, 45, 0.8);
        border-color: rgba(0,207,255,0.08);
    }

    .pedido-rog-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
        padding-bottom: 15px;
        border-bottom: 1px solid rgba(255,255,255,0.03);
        margin-bottom: 15px;
    }

    .pedido-rog-header .ref {
        color: #FFFFFF;
        font-size: 0.9rem;
    }

    .pedido-rog-header .ref strong {
        color: #fff;
    }

    .pedido-rog-header .fecha {
        color: #FFFFFF;
        font-size: 0.8rem;
    }

    .badge-rog-estado {
        padding: 5px 18px;
        border-radius: 50px;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .badge-rog-estado.confirmado {
        background: rgba(6, 214, 160, 0.1);
        color: #06d6a0;
        border: 1px solid rgba(6, 214, 160, 0.05);
    }

    .badge-rog-estado.pendiente {
        background: rgba(248, 150, 30, 0.1);
        color: #f8961e;
        border: 1px solid rgba(248, 150, 30, 0.05);
    }

    .badge-rog-estado.enviado {
        background: rgba(76, 201, 240, 0.1);
        color: #4cc9f0;
        border: 1px solid rgba(76, 201, 240, 0.05);
    }

    .badge-rog-estado.entregado {
        background: rgba(6, 214, 160, 0.1);
        color: #06d6a0;
        border: 1px solid rgba(6, 214, 160, 0.05);
    }

    .badge-rog-estado.cancelado {
        background: rgba(239, 71, 111, 0.1);
        color: #ef476f;
        border: 1px solid rgba(239, 71, 111, 0.05);
    }

    .pedido-rog-productos {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 15px;
        margin: 15px 0;
    }

    .pedido-rog-producto {
        background: rgba(255,255,255,0.02);
        border-radius: 10px;
        padding: 12px;
        border: 1px solid rgba(255,255,255,0.02);
    }

    .pedido-rog-producto .nombre {
        color: #fff;
        font-weight: 500;
        font-size: 0.9rem;
    }

    .pedido-rog-producto .detalle {
        color: #FFFFFF;
        font-size: 0.8rem;
    }

    .pedido-rog-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
        padding-top: 15px;
        border-top: 1px solid rgba(255,255,255,0.03);
        margin-top: 15px;
    }

    .pedido-rog-footer .total {
        color: #00CFFF;
        font-size: 1.5rem;
        font-weight: 900;
    }

    .pedido-rog-footer .total-label {
        color: #FFFFFF;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .btn-rog-primary {
        background: linear-gradient(135deg, #00CFFF, #7A00FF);
        color: #fff;
        border: none;
        border-radius: 50px;
        padding: 14px 40px;
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

    .btn-rog-primary:hover {
        transform: translateY(-3px);
        box-shadow: 0 0 30px rgba(0,207,255,0.2);
        color: #fff;
    }

    .btn-rog-outline {
        background: transparent;
        border: 1px solid rgba(255,255,255,0.06);
        color: #FFFFFF;
        border-radius: 50px;
        padding: 14px 40px;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

    .btn-rog-outline:hover {
        border-color: #00CFFF;
        color: #fff;
    }

    .sin-compras-rog {
        text-align: center;
        padding: 80px 20px;
    }

    .sin-compras-rog i {
        font-size: 4rem;
        color: #FFFFFF;
        margin-bottom: 20px;
    }

    .sin-compras-rog h3 {
        color: #FFFFFF;
        font-weight: 300;
    }

    .sin-compras-rog p {
        color: #FFFFFF;
    }

    .alert-rog-success {
        background: rgba(6, 214, 160, 0.08);
        border: 1px solid rgba(6, 214, 160, 0.1);
        border-radius: 16px;
        padding: 20px 25px;
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        gap: 15px;
        color: #06d6a0;
        font-size: 1.05rem;
        animation: fadeInDown 0.5s ease-out;
    }

    .alert-rog-success i {
        font-size: 1.8rem;
    }

    .alert-rog-success .btn-close {
        filter: brightness(0) invert(1);
        opacity: 0.2;
        margin-left: auto;
    }

    .alert-rog-success .btn-close:hover {
        opacity: 0.5;
    }

    @@keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 768px) {
        .pedido-rog-header {
            flex-direction: column;
            align-items: stretch;
            text-align: center;
        }

        .pedido-rog-footer {
            flex-direction: column;
            align-items: stretch;
            text-align: center;
        }

        .pedido-rog-productos {
            grid-template-columns: 1fr 1fr;
        }
    }
</style>

<div class="compras-rog-container">
    <div class="container">

        @if (TempData["Mensaje"] != null)
        {
            <div class="alert-rog-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                <span>@TempData["Mensaje"]</span>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
            <h1><i class="bi bi-box-seam me-2" style="color: #00CFFF;"></i>Mis <span>Compras</span></h1>
            <a asp-controller="Tienda" asp-action="Index" class="btn-rog-outline">
                <i class="bi bi-arrow-left me-2"></i>Seguir comprando
            </a>
        </div>

        @if (pedidos.Any())
        {
            @foreach (var pedido in pedidos)
            {
                <div class="pedido-rog-card">
                    <div class="pedido-rog-header">
                        <div>
                            <div class="ref">
                                <strong>REF:</strong> #@pedido.NumeroReferencia
                            </div>
                            <div class="fecha">
                                <i class="bi bi-calendar3 me-1"></i>
                                @pedido.FechaPedido.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        </div>
                        <div>
                            <span class="badge-rog-estado @pedido.Estado.ToString().ToLower()">
                                @GetEstadoTexto(pedido.Estado)
                            </span>
                        </div>
                    </div>

                    <div class="pedido-rog-productos">
                        @if (pedido.Detalles != null)
                        {
                            @foreach (var detalle in pedido.Detalles)
                            {
                                <div class="pedido-rog-producto">
                                    <div class="nombre">@detalle.Producto?.Nombre</div>
                                    <div class="detalle">
                                        @detalle.Cantidad x Bs @detalle.PrecioUnitario.ToString("N0")
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    <div class="pedido-rog-footer">
                        <div>
                            <span class="total-label">Total</span>
                            <div class="total">Bs @pedido.Total.ToString("N0")</div>
                        </div>
                        <div>
                            <span style="color: #FFFFFF; font-size: 0.85rem;">
                                <i class="bi bi-truck me-1"></i>
                                @(pedido.Estado == EstadoPedido.Confirmado ? "Preparando pedido" :
                                  pedido.Estado == EstadoPedido.Enviado ? "En camino" :
                                  pedido.Estado == EstadoPedido.Entregado ? "Entregado" :
                                  pedido.Estado == EstadoPedido.Cancelado ? "Cancelado" : "Pendiente")
                            </span>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="sin-compras-rog">
                <i class="bi bi-box-seam"></i>
                <h3>No tienes compras realizadas</h3>
                <p>Explora nuestra tienda y haz tu primera compra</p>
                <a asp-controller="Tienda" asp-action="Index" class="btn-rog-primary mt-3 d-inline-block">
                    <i class="bi bi-shop me-2"></i>Ir a la tienda
                </a>
            </div>
        }
    </div>
</div>

@functions {
    string GetEstadoTexto(EstadoPedido estado)
    {
        switch (estado)
        {
            case EstadoPedido.Confirmado: return "Confirmado";
            case EstadoPedido.Pendiente: return "Pendiente";
            case EstadoPedido.Enviado: return "Enviado";
            case EstadoPedido.Entregado: return "Entregado";
            case EstadoPedido.Cancelado: return "Cancelado";
            default: return estado.ToString();
        }
    }
}